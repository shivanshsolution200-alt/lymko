{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign customer_name = customer.metafields.custom.full_name.value | default: customer.metafields.custom.full_name | default: customer.name
  assign customer_email = customer.metafields.custom.email.value | default: customer.metafields.custom.email | default: customer.email
  assign customer_phone = customer.metafields.custom.phone.value | default: customer.metafields.custom.phone | default: customer.phone
-%}

{% unless customer %}
  <script>window.location.replace('/customer_authentication/login?return_to=%2Fpages%2Fdashboard');</script>
{% endunless %}

{% if customer %}
<div class="ldash">
  {%- assign ldash_orders_count = customer.orders_count | default: 0 -%}
  {%- assign ldash_orders_size = customer.orders.size | default: 0 -%}

  {% if ldash_orders_count > 0 and ldash_orders_size == 0 %}
    <div class="ldash__order-sync-note">
      <div>
        <strong>Your orders are available in your Shopify account.</strong>
        <span>The storefront session has not exposed the order list on this page.</span>
      </div>
      <a href="https://account.lymko.in/orders">View all orders</a>
    </div>
  {% endif %}
  <div class="ldash__head">
    <h1>Welcome, {{ customer.first_name | default: customer.name }}!</h1>
    <a href="{{ routes.account_logout_url }}" class="ldash__logout">
      <svg viewBox="0 0 24 24"><path d="M10 5H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h4M15 8l4 4-4 4M9 12h10"/></svg>
      Logout
    </a>
  </div>

  <div class="ldash__tabs" role="tablist">
    <button class="ldash__tab is-active" data-tab="profile" type="button">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c0-4 2.8-7 7-7s7 3 7 7"/></svg>
      My profile
    </button>
    <button class="ldash__tab" data-tab="orders" type="button">
      <svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg>
      Orders
    </button>
    <button class="ldash__tab" data-tab="addresses" type="button">
      <svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>
      Addresses
    </button>
    <button class="ldash__tab" data-tab="recent" type="button">
      <svg viewBox="0 0 24 24"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg>
      Recently viewed
    </button>
    <button class="ldash__tab" data-tab="top" type="button">
      <svg viewBox="0 0 24 24"><path d="M12 3v18M7 8l5-5 5 5M6 16h12"/></svg>
      Top ordered products
    </button>
  </div>

  <div id="ldash-profile" class="ldash__panel is-active">
    <div class="ldash__grid">
      <article class="ldash__card">
        <header class="ldash__card-head">
          <h2><span><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c0-4 2.8-7 7-7s7 3 7 7"/></svg></span>Account Details</h2>
          <a href="https://account.lymko.in/profile" class="ldash__edit" title="Edit profile">
            <svg viewBox="0 0 24 24"><path d="m4 20 4.5-1 10-10-3.5-3.5-10 10L4 20Z"/><path d="m13.5 6.5 3.5 3.5"/></svg>
          </a>
        </header>
        <div class="ldash__card-body">
          <p class="ldash__detail"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c0-4 2.8-7 7-7s7 3 7 7"/></svg>{{ customer_name }}</p>
          {% if customer_phone != blank %}<p class="ldash__detail"><svg viewBox="0 0 24 24"><path d="M7 3h3l1 5-2 1c1.2 2.8 3.4 5 6.2 6.2l1-2 4.8 1V17c0 2.2-1.8 4-4 4C9.3 21 3 14.7 3 7c0-2.2 1.8-4 4-4Z"/></svg>{{ customer_phone }}</p>{% endif %}
          <p class="ldash__detail"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>{{ customer_email }}</p>
        </div>
      </article>

      <article class="ldash__card">
        <header class="ldash__card-head">
          <h2><span><svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg></span>Default Address</h2>
          <a href="https://account.lymko.in/profile" class="ldash__text-link">View all</a>
        </header>
        <div class="ldash__card-body">
          {% if customer.default_address %}
            <div class="ldash__address">{{ customer.default_address | format_address }}</div>
          {% else %}
            <div class="ldash__empty-address">
              <svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>
              <span>No addresses added</span>
              <a href="https://account.lymko.in/profile" class="ldash__small-btn">Add</a>
            </div>
          {% endif %}
        </div>
      </article>
    </div>

    <article class="ldash__card ldash__orders-card">
      <header class="ldash__card-head">
        <h2><span><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>Recent Orders</h2>
      </header>
      <div class="ldash__card-body">
        
        {% if customer.orders.size > 0 %}
          <div class="ldash__order-list">
            {% for order in customer.orders limit: 3 %}
              <div class="ldash__order-item">
                <div class="ldash__order-product">
                  <div class="ldash__order-image">
                    {% if order.line_items.first.image %}
                      <img src="{{ order.line_items.first.image | image_url: width: 90, height: 90, crop: 'center' }}" alt="{{ order.line_items.first.title | escape }}" loading="lazy">
                    {% else %}
                      <div class="ldash__order-image-placeholder"><svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg></div>
                    {% endif %}
                  </div>
                  <div class="ldash__order-info">
                    <div class="ldash__order-top-line">
                      <strong>{{ order.name }}</strong>
                      <span class="ldash__status ldash__status--{{ order.financial_status }}">{{ order.financial_status_label }}</span>
                      <span class="ldash__status ldash__status--{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span>
                    </div>
                    <span class="ldash__order-date">{{ order.created_at | date: "%B %d, %Y" }}</span>
                  </div>
                </div>
                <div class="ldash__order-total"><strong>{{ order.total_price | money }}</strong><span>{{ order.item_count }} {% if order.item_count == 1 %}item{% else %}items{% endif %}</span></div>
                <div class="ldash__order-actions">
                  <a href="{{ order.customer_url }}" class="ldash__order-btn ldash__order-btn--outline">View details</a>
                  {% capture reorder_items %}[{% for item in order.line_items %}{"id": {{ item.variant_id | json }}, "quantity": {{ item.quantity | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]{% endcapture %}
                  <button type="button" class="ldash__order-btn ldash__order-btn--dark" onclick='ldashReorder({{ reorder_items | strip }})'>Reorder</button>
                  <button type="button" class="ldash__order-btn ldash__order-btn--invoice" onclick="ldashDownloadInvoice('invoice-{{ order.id }}', '{{ order.name | escape }}')">Download Invoice</button>
                </div>
                <div id="invoice-{{ order.id }}" class="ldash__invoice-template">
                  <div class="ldash__invoice">
                    <div class="ldash__invoice-header"><div><h1>{{ shop.name }}</h1><p>Tax Invoice</p></div><div class="ldash__invoice-number"><strong>{{ order.name }}</strong><span>{{ order.created_at | date: "%B %d, %Y" }}</span></div></div>
                    <div class="ldash__invoice-customer"><div><h3>Bill To</h3><p>{{ customer.name }}</p><p>{{ customer.email }}</p>{% if customer.phone != blank %}<p>{{ customer.phone }}</p>{% endif %}</div><div><h3>Shipping Address</h3>{% if order.shipping_address %}{{ order.shipping_address | format_address }}{% elsif customer.default_address %}{{ customer.default_address | format_address }}{% else %}<p>No shipping address available.</p>{% endif %}</div></div>
                    <table class="ldash__invoice-table"><thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead><tbody>{% for item in order.line_items %}<tr><td><strong>{{ item.product.title | default: item.title }}</strong>{% unless item.variant.title == 'Default Title' %}<small>{{ item.variant.title }}</small>{% endunless %}</td><td>{{ item.quantity }}</td><td>{{ item.final_price | money }}</td><td>{{ item.final_line_price | money }}</td></tr>{% endfor %}</tbody></table>
                    <div class="ldash__invoice-summary"><div><span>Subtotal</span><strong>{{ order.subtotal_price | money }}</strong></div>{% for shipping_method in order.shipping_methods %}<div><span>{{ shipping_method.title }}</span><strong>{{ shipping_method.price | money }}</strong></div>{% endfor %}{% if order.total_discounts > 0 %}<div><span>Discount</span><strong>-{{ order.total_discounts | money }}</strong></div>{% endif %}<div class="ldash__invoice-grand-total"><span>Total</span><strong>{{ order.total_price | money_with_currency }}</strong></div></div>
                    <div class="ldash__invoice-footer"><p>Thank you for shopping with {{ shop.name }}.</p></div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="ldash__empty-orders">
            <div class="ldash__bag"><svg viewBox="0 0 64 64"><circle cx="32" cy="32" r="27"/><path d="M22 25h20l-2 20H24l-2-20Z"/><path d="M27 25a5 5 0 0 1 10 0"/><path d="M45 18v8M41 22h8"/></svg></div>

            {% if customer.orders_count > 0 %}
              <h3>Your order exists, but Shopify has not exposed it to this custom page.</h3>
              <p>Open your secure Shopify Orders page to see the complete order history and order details.</p>
              <a href="https://account.lymko.in/orders" class="ldash__primary">View My Orders</a>
            {% else %}
              <h3>You haven't placed any orders yet.</h3>
              <p>Place an order using the same email address as this logged-in customer account.</p>
              <a href="{{ routes.collections_url }}" class="ldash__primary">Explore Collections</a>
            {% endif %}
          </div>
        {% endif %}

        <div class="ldash__trust">
          <div><strong>Secure Checkout</strong><span>Safe and protected payments.</span></div>
          <div><strong>Fast Delivery</strong><span>Quick updates on every order.</span></div>
          <div><strong>24/7 Support</strong><span>Help whenever you need it.</span></div>
        </div>
      </div>
    </article>
  </div>

  <div id="ldash-orders" class="ldash__panel">
    <article class="ldash__card">
      <header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg></span>Order History</h2></header>
      <div class="ldash__card-body">
        {% paginate customer.orders by 10 %}
          {% if customer.orders.size > 0 %}
            <div class="ldash__order-list">
              {% for order in customer.orders %}
                <div class="ldash__order-item">
                  <div class="ldash__order-product"><div class="ldash__order-image">{% if order.line_items.first.image %}<img src="{{ order.line_items.first.image | image_url: width: 90, height: 90, crop: 'center' }}" alt="{{ order.line_items.first.title | escape }}" loading="lazy">{% else %}<div class="ldash__order-image-placeholder"><svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg></div>{% endif %}</div><div class="ldash__order-info"><div class="ldash__order-top-line"><strong>{{ order.name }}</strong><span class="ldash__status ldash__status--{{ order.financial_status }}">{{ order.financial_status_label }}</span><span class="ldash__status ldash__status--{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span></div><span class="ldash__order-date">{{ order.created_at | date: "%B %d, %Y" }}</span></div></div>
                  <div class="ldash__order-total"><strong>{{ order.total_price | money }}</strong><span>{{ order.item_count }} {% if order.item_count == 1 %}item{% else %}items{% endif %}</span></div>
                  <div class="ldash__order-actions"><a href="{{ order.customer_url }}" class="ldash__order-btn ldash__order-btn--outline">View details</a>{% capture reorder_items %}[{% for item in order.line_items %}{"id": {{ item.variant_id | json }}, "quantity": {{ item.quantity | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]{% endcapture %}<button type="button" class="ldash__order-btn ldash__order-btn--dark" onclick='ldashReorder({{ reorder_items | strip }})'>Reorder</button><button type="button" class="ldash__order-btn ldash__order-btn--invoice" onclick="ldashDownloadInvoice('invoice-full-{{ order.id }}', '{{ order.name | escape }}')">Download Invoice</button></div>
                  <div id="invoice-full-{{ order.id }}" class="ldash__invoice-template"><div class="ldash__invoice"><div class="ldash__invoice-header"><div><h1>{{ shop.name }}</h1><p>Tax Invoice</p></div><div class="ldash__invoice-number"><strong>{{ order.name }}</strong><span>{{ order.created_at | date: "%B %d, %Y" }}</span></div></div><div class="ldash__invoice-customer"><div><h3>Bill To</h3><p>{{ customer.name }}</p><p>{{ customer.email }}</p>{% if customer.phone != blank %}<p>{{ customer.phone }}</p>{% endif %}</div><div><h3>Shipping Address</h3>{% if order.shipping_address %}{{ order.shipping_address | format_address }}{% elsif customer.default_address %}{{ customer.default_address | format_address }}{% else %}<p>No shipping address available.</p>{% endif %}</div></div><table class="ldash__invoice-table"><thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead><tbody>{% for item in order.line_items %}<tr><td><strong>{{ item.product.title | default: item.title }}</strong>{% unless item.variant.title == 'Default Title' %}<small>{{ item.variant.title }}</small>{% endunless %}</td><td>{{ item.quantity }}</td><td>{{ item.final_price | money }}</td><td>{{ item.final_line_price | money }}</td></tr>{% endfor %}</tbody></table><div class="ldash__invoice-summary"><div><span>Subtotal</span><strong>{{ order.subtotal_price | money }}</strong></div>{% for shipping_method in order.shipping_methods %}<div><span>{{ shipping_method.title }}</span><strong>{{ shipping_method.price | money }}</strong></div>{% endfor %}{% if order.total_discounts > 0 %}<div><span>Discount</span><strong>-{{ order.total_discounts | money }}</strong></div>{% endif %}<div class="ldash__invoice-grand-total"><span>Total</span><strong>{{ order.total_price | money_with_currency }}</strong></div></div><div class="ldash__invoice-footer"><p>Thank you for shopping with {{ shop.name }}.</p></div></div></div>
                </div>
              {% endfor %}
            </div>
            {% if paginate.pages > 1 %}<div class="ldash__pagination">{{ paginate | default_pagination }}</div>{% endif %}
          {% else %}
            <div class="ldash__empty-orders ldash__empty-orders--orders-tab">
                {{ customer_email }}
<div class="ldash__order-list">
              {% for order in customer.orders %}
                <div class="ldash__order-item">
                  <div class="ldash__order-product"><div class="ldash__order-image">{% if order.line_items.first.image %}<img src="{{ order.line_items.first.image | image_url: width: 90, height: 90, crop: 'center' }}" alt="{{ order.line_items.first.title | escape }}" loading="lazy">{% else %}<div class="ldash__order-image-placeholder"><svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg></div>{% endif %}</div><div class="ldash__order-info"><div class="ldash__order-top-line"><strong>{{ order.name }}</strong><span class="ldash__status ldash__status--{{ order.financial_status }}">{{ order.financial_status_label }}</span><span class="ldash__status ldash__status--{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span></div><span class="ldash__order-date">{{ order.created_at | date: "%B %d, %Y" }}</span></div></div>
                  <div class="ldash__order-total"><strong>{{ order.total_price | money }}</strong><span>{{ order.item_count }} {% if order.item_count == 1 %}item{% else %}items{% endif %}</span></div>
                  <div class="ldash__order-actions"><a href="{{ order.customer_url }}" class="ldash__order-btn ldash__order-btn--outline">View details</a>{% capture reorder_items %}[{% for item in order.line_items %}{"id": {{ item.variant_id | json }}, "quantity": {{ item.quantity | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]{% endcapture %}<button type="button" class="ldash__order-btn ldash__order-btn--dark" onclick='ldashReorder({{ reorder_items | strip }})'>Reorder</button><button type="button" class="ldash__order-btn ldash__order-btn--invoice" onclick="ldashDownloadInvoice('invoice-full-{{ order.id }}', '{{ order.name | escape }}')">Download Invoice</button></div>
                  <div id="invoice-full-{{ order.id }}" class="ldash__invoice-template"><div class="ldash__invoice"><div class="ldash__invoice-header"><div><h1>{{ shop.name }}</h1><p>Tax Invoice</p></div><div class="ldash__invoice-number"><strong>{{ order.name }}</strong><span>{{ order.created_at | date: "%B %d, %Y" }}</span></div></div><div class="ldash__invoice-customer"><div><h3>Bill To</h3><p>{{ customer.name }}</p><p>{{ customer.email }}</p>{% if customer.phone != blank %}<p>{{ customer.phone }}</p>{% endif %}</div><div><h3>Shipping Address</h3>{% if order.shipping_address %}{{ order.shipping_address | format_address }}{% elsif customer.default_address %}{{ customer.default_address | format_address }}{% else %}<p>No shipping address available.</p>{% endif %}</div></div><table class="ldash__invoice-table"><thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead><tbody>{% for item in order.line_items %}<tr><td><strong>{{ item.product.title | default: item.title }}</strong>{% unless item.variant.title == 'Default Title' %}<small>{{ item.variant.title }}</small>{% endunless %}</td><td>{{ item.quantity }}</td><td>{{ item.final_price | money }}</td><td>{{ item.final_line_price | money }}</td></tr>{% endfor %}</tbody></table><div class="ldash__invoice-summary"><div><span>Subtotal</span><strong>{{ order.subtotal_price | money }}</strong></div>{% for shipping_method in order.shipping_methods %}<div><span>{{ shipping_method.title }}</span><strong>{{ shipping_method.price | money }}</strong></div>{% endfor %}{% if order.total_discounts > 0 %}<div><span>Discount</span><strong>-{{ order.total_discounts | money }}</strong></div>{% endif %}<div class="ldash__invoice-grand-total"><span>Total</span><strong>{{ order.total_price | money_with_currency }}</strong></div></div><div class="ldash__invoice-footer"><p>Thank you for shopping with {{ shop.name }}.</p></div></div></div>
                </div>
              {% endfor %}
            </div>
              {% if customer.orders_count > 0 %}
                <h3>Your orders are available in Shopify Customer Accounts.</h3>
                <p>This custom storefront page did not receive the private order list from the current customer-account session.</p>
                <a href="https://account.lymko.in/orders" class="ldash__primary">Open Order History</a>
              {% else %}
                <h3>No orders found.</h3>
                <p>Make sure the checkout email exactly matches <strong>{{ customer.email }}</strong>.</p>
                <a href="{{ routes.collections_url }}" class="ldash__primary">Start Shopping</a>
              {% endif %}
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </article>
  </div>

  <div id="ldash-addresses" class="ldash__panel">
    <article class="ldash__card">
      <header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg></span>Saved Addresses</h2><a href="https://account.lymko.in/profile" class="ldash__small-btn">Add</a></header>
      <div class="ldash__card-body">
        {% if customer.addresses.size > 0 %}<div class="ldash__address-grid">{% for address in customer.addresses %}<div class="ldash__address-card">{% if address == customer.default_address %}<span>Default</span>{% endif %}{{ address | format_address }}</div>{% endfor %}</div>{% else %}<p class="ldash__muted">No addresses added.</p>{% endif %}
      </div>
    </article>
  </div>

  <div id="ldash-recent" class="ldash__panel">
    <article class="ldash__card"><header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg></span>Recently Viewed Products</h2></header><div class="ldash__card-body"><div class="ldash__products" id="ldash-recent-grid"><p class="ldash__muted">No recently viewed products found.</p></div></div></article>
  </div>

  <div id="ldash-top" class="ldash__panel">
    <article class="ldash__card"><header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M12 3v18M7 8l5-5 5 5M6 16h12"/></svg></span>Top Ordered Products</h2></header><div class="ldash__card-body"><p class="ldash__muted">Your frequently ordered products will appear here.</p></div></article>
  </div>
</div>

<style>
.ldash{--p:#6f3cff;--ps:#f1edff;--b:#ececf1;--m:#6c7280;max-width:1280px;margin:auto;padding:28px 22px 60px;color:#111}.ldash *{box-sizing:border-box}.ldash svg{width:20px;height:20px;fill:none;stroke:currentColor;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}.ldash__head{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:26px}.ldash__head h1{margin:0;font-size:clamp(22px,2.4vw,34px)}.ldash__logout{display:flex;align-items:center;gap:8px;padding:10px 17px;border:1px solid #d9dbe2;border-radius:9px;color:#111;text-decoration:none}.ldash__tabs{display:flex;gap:8px;padding:12px 16px 0;margin-bottom:28px;overflow:auto;border:1px solid var(--b);border-radius:14px;background:#fff}.ldash__tab{position:relative;display:flex;align-items:center;gap:9px;white-space:nowrap;padding:0 16px 13px;min-height:50px;border:0;border-radius:8px 8px 0 0;background:transparent;color:#4e5563;cursor:pointer}.ldash__tab:after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:transparent}.ldash__tab.is-active{background:var(--ps);color:var(--p)}.ldash__tab.is-active:after{background:var(--p)}.ldash__panel{display:none}.ldash__panel.is-active{display:block}.ldash__grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.ldash__card{overflow:hidden;border:1px solid var(--b);border-radius:14px;background:#fff;box-shadow:0 5px 18px rgba(0,0,0,.035)}.ldash__card-head{min-height:72px;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--b)}.ldash__card-head h2{display:flex;align-items:center;gap:10px;margin:0;font-size:18px}.ldash__card-head h2 span{display:grid;place-items:center;width:34px;height:34px;border-radius:50%;background:var(--ps);color:var(--p)}.ldash__card-body{padding:22px}.ldash__edit,.ldash__text-link{color:#111;text-decoration:none}.ldash__detail{display:flex;align-items:center;gap:13px;margin:0 0 20px;font-size:15px}.ldash__detail:last-child{margin-bottom:0}.ldash__address address,.ldash__address-card address{font-style:normal;line-height:1.6}.ldash__empty-address{min-height:120px;display:flex;align-items:center;gap:14px}.ldash__empty-address>svg{width:46px;height:46px;padding:12px;border-radius:12px;background:#f7f7f9}.ldash__empty-address span{flex:1;color:var(--m)}.ldash__small-btn{display:inline-flex;align-items:center;justify-content:center;min-width:48px;height:38px;padding:0 14px;border:1px solid #dadce3;border-radius:10px;color:#111;text-decoration:none;background:#fff}.ldash__orders-card{margin-top:24px}.ldash__empty-orders{text-align:center;padding:34px 20px 24px}.ldash__bag{width:86px;height:86px;margin:0 auto 22px;color:var(--p)}.ldash__bag svg{width:86px;height:86px}.ldash__bag circle{fill:var(--ps);stroke:none}.ldash__empty-orders h3{margin:0 0 12px}.ldash__empty-orders p{max-width:620px;margin:0 auto 20px;color:var(--m);line-height:1.6}.ldash__primary{display:inline-flex;min-height:46px;padding:0 22px;align-items:center;border-radius:7px;background:#000;color:#fff;text-decoration:none}.ldash__trust{display:grid;grid-template-columns:repeat(3,1fr);margin-top:28px;border:1px solid #f2d0c7;border-radius:10px;overflow:hidden}.ldash__trust>div{padding:18px;text-align:center;background:#fffdfc}.ldash__trust>div+div{border-left:1px solid #f2d0c7}.ldash__trust strong,.ldash__trust span{display:block}.ldash__trust span{margin-top:5px;color:var(--m);font-size:12px}.ldash__order-list{display:grid;gap:14px}.ldash__order-row{display:flex;justify-content:space-between;padding:16px;border:1px solid var(--b);border-radius:12px}.ldash__order-row span,.ldash__order-row a{display:block;margin-top:5px}.ldash__order-row span{color:var(--m);font-size:13px}.ldash__order-row a{color:var(--p);text-decoration:none}.ldash__table-wrap{overflow:auto}.ldash__table{width:100%;border-collapse:collapse}.ldash__table th,.ldash__table td{padding:14px 12px;border-bottom:1px solid var(--b);text-align:left;white-space:nowrap}.ldash__table a{color:var(--p);text-decoration:none}.ldash__address-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.ldash__address-card{position:relative;min-height:160px;padding:20px;border:1px solid var(--b);border-radius:12px}.ldash__address-card>span{position:absolute;top:12px;right:12px;padding:4px 8px;border-radius:20px;background:var(--ps);color:var(--p);font-size:11px}.ldash__products{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.ldash__product{overflow:hidden;border:1px solid var(--b);border-radius:12px}.ldash__product a{color:inherit;text-decoration:none}.ldash__product img{width:100%;aspect-ratio:1;object-fit:cover}.ldash__product h3,.ldash__product strong{display:block;padding:0 14px}.ldash__product h3{font-size:14px}.ldash__product strong{padding-bottom:16px;color:var(--p)}.ldash__muted{color:var(--m)}
@media(max-width:900px){.ldash__grid,.ldash__address-grid{grid-template-columns:1fr}.ldash__products{grid-template-columns:repeat(2,1fr)}}
@media(max-width:640px){.ldash{padding:20px 12px 48px}.ldash__head{align-items:flex-start}.ldash__trust{grid-template-columns:1fr}.ldash__trust>div+div{border-left:0;border-top:1px solid #f2d0c7}.ldash__order-row{flex-direction:column;gap:12px}}

.ldash__order-item{display:grid;grid-template-columns:minmax(260px,1fr) auto auto;align-items:center;gap:24px;padding:20px 16px;border-bottom:1px solid #ececf1}.ldash__order-item:last-child{border-bottom:none}.ldash__order-product{display:flex;align-items:center;gap:18px;min-width:0}.ldash__order-image{flex:0 0 72px;width:72px;height:72px}.ldash__order-image img,.ldash__order-image-placeholder{display:block;width:72px;height:72px;border-radius:8px;object-fit:cover;background:#f6f6f6}.ldash__order-image-placeholder{display:flex;align-items:center;justify-content:center}.ldash__order-info{min-width:0}.ldash__order-top-line{display:flex;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:10px}.ldash__order-top-line>strong{font-size:15px}.ldash__order-date{display:block;color:#3f4652;font-size:13px}.ldash__status{display:inline-flex;align-items:center;min-height:28px;padding:4px 11px;border-radius:7px;font-size:12px;font-weight:600;text-transform:capitalize}.ldash__status--paid,.ldash__status--fulfilled{color:#147a45;background:#ddf6e8}.ldash__status--pending,.ldash__status--authorized{color:#986600;background:#fff1c9}.ldash__status--unfulfilled,.ldash__status--partial{color:#b05d00;background:#fff0d3}.ldash__status--refunded,.ldash__status--voided{color:#b42318;background:#fee4e2}.ldash__order-total{min-width:90px;text-align:right}.ldash__order-total strong,.ldash__order-total span{display:block}.ldash__order-total strong{margin-bottom:5px;font-size:15px}.ldash__order-total span{font-size:13px;color:#303642}.ldash__order-actions{display:flex;align-items:center;gap:10px}.ldash__order-btn{display:inline-flex;align-items:center;justify-content:center;min-height:42px;padding:8px 19px;border-radius:9px;font-family:inherit;font-size:13px;font-weight:650;text-decoration:none;cursor:pointer;white-space:nowrap;transition:.2s ease}.ldash__order-btn--outline{border:1px solid #d9dce3;background:#fff;color:#222}.ldash__order-btn--dark{border:1px solid #000;background:#000;color:#fff}.ldash__order-btn--invoice{border:1px solid #6f3cff;background:#f1edff;color:#6f3cff}.ldash__order-btn:hover{transform:translateY(-1px)}.ldash__invoice-template{display:none}.ldash__invoice{width:760px;padding:38px;background:#fff;color:#111;font-family:Arial,sans-serif}.ldash__invoice-header,.ldash__invoice-customer{display:flex;justify-content:space-between;gap:30px}.ldash__invoice-header{padding-bottom:24px;border-bottom:2px solid #111}.ldash__invoice-header h1,.ldash__invoice-header p{margin:0}.ldash__invoice-header h1{margin-bottom:6px;font-size:28px}.ldash__invoice-number{text-align:right}.ldash__invoice-number strong,.ldash__invoice-number span{display:block}.ldash__invoice-customer{margin:28px 0}.ldash__invoice-customer>div{width:50%}.ldash__invoice-customer h3{margin:0 0 10px}.ldash__invoice-customer p,.ldash__invoice-customer address{margin:0 0 5px;font-style:normal;line-height:1.5}.ldash__invoice-table{width:100%;border-collapse:collapse}.ldash__invoice-table th,.ldash__invoice-table td{padding:12px;border:1px solid #ddd;text-align:left}.ldash__invoice-table th{background:#f5f5f5}.ldash__invoice-table small{display:block;margin-top:4px;color:#666}.ldash__invoice-summary{width:330px;margin:25px 0 0 auto}.ldash__invoice-summary>div{display:flex;justify-content:space-between;gap:20px;padding:7px 0}.ldash__invoice-grand-total{margin-top:8px;padding-top:14px!important;border-top:2px solid #111;font-size:17px}.ldash__invoice-footer{margin-top:40px;padding-top:18px;border-top:1px solid #ddd;text-align:center}@media(max-width:900px){.ldash__order-item{grid-template-columns:1fr auto}.ldash__order-actions{grid-column:1/-1;flex-wrap:wrap}}@media(max-width:600px){.ldash__order-item{grid-template-columns:1fr}.ldash__order-total{text-align:left}.ldash__order-actions{grid-column:auto}.ldash__order-btn{flex:1}}

.ldash__order-sync-note{display:flex;align-items:center;justify-content:space-between;gap:18px;margin:0 0 22px;padding:16px 18px;border:1px solid #eadfff;border-radius:12px;background:#faf8ff}.ldash__order-sync-note div{display:flex;flex-direction:column;gap:4px}.ldash__order-sync-note strong{font-size:14px}.ldash__order-sync-note span{color:var(--m);font-size:13px}.ldash__order-sync-note a{display:inline-flex;align-items:center;justify-content:center;min-height:40px;padding:0 16px;border-radius:8px;background:var(--p);color:#fff;text-decoration:none;font-size:13px;font-weight:600}.ldash__empty-orders--orders-tab{padding-top:24px;padding-bottom:24px}
