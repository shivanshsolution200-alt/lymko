/* Exact order-detail design */
.ldash{
  max-width: 940px;
  padding: 24px 0 42px;
}
.ldash__head{
  margin-bottom: 20px;
}
.ldash__head h1{
  font-size: 24px;
  line-height: 1.2;
  font-weight: 700;
}
.ldash__logout{
  min-height: 40px;
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  background:#fff;
}
.ldash__tabs{
  min-height: 70px;
  align-items: center;
  margin-bottom: 26px;
  padding: 12px 18px 0;
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(17,24,39,.035);
}
.ldash__tab{
  min-height: 54px;
  padding: 0 18px 14px;
  font-size: 13px;
}
.ldash__tab.is-active{
  background:#dbeed3;
  color:#111;
}
.ldash__tab.is-active:after{
  height:2px;
  background:#111;
}
.ldash__order-detail-wrap{
  width:100%;
}
.ldash__order-detail-head{
  min-height: 58px;
  margin-bottom: 24px;
  align-items: flex-start;
}
.ldash__order-title-wrap{
  gap: 14px;
}
.ldash__back-btn{
  width: 22px;
  height: 34px;
  padding:0;
  background:transparent;
  border-radius:0;
  color:#444;
}
.ldash__back-btn svg{
  width:22px;
  height:22px;
}
.ldash__order-title-wrap h2{
  margin:0 0 6px;
  font-size:24px;
  line-height:1.15;
  font-weight:700;
}
.ldash__order-title-wrap p{
  font-size:13px;
  color:#333;
}
.ldash__detail-actions{
  margin-top:0;
}
.ldash__detail-actions .ldash__order-btn--invoice{
  display:none;
}
.ldash__detail-actions .ldash__order-btn--dark{
  min-width:92px;
  min-height:34px;
  padding:7px 18px;
  border-radius:7px;
  font-size:12px;
}
.ldash__order-detail-grid{
  grid-template-columns:minmax(0, 1.58fr) minmax(300px, 1fr);
  gap:24px;
  align-items:start;
}
.ldash__order-detail-left{
  gap:24px;
}
.ldash__card,
.ldash__order-summary-card{
  border:1px solid #ececec;
  border-radius:12px;
  box-shadow:0 3px 9px rgba(0,0,0,.07);
}
.ldash__status-card .ldash__card-body{
  min-height:108px;
  padding:20px 18px;
}
.ldash__detail-section-title{
  margin:0 0 8px;
  font-size:16px;
  font-weight:650;
}
.ldash__detail-status-copy{
  font-size:13px;
  color:#404040;
}
.ldash__info-grid{
  grid-template-columns:1fr 1fr;
  gap:28px 44px;
}
.ldash__order-detail-left .ldash__card:nth-child(2) .ldash__card-body{
  min-height:374px;
  padding:22px 22px 18px;
}
.ldash__info-grid h3{
  margin:0 0 11px;
  font-size:14px;
  font-weight:650;
}
.ldash__info-grid p,
.ldash__info-grid address{
  margin:0 0 6px;
  font-size:13px;
  line-height:1.45;
}
.ldash__order-summary-card{
  padding:20px;
}
.ldash__summary-products{
  gap:16px;
  padding-bottom:22px;
}
.ldash__summary-product{
  grid-template-columns:58px minmax(0,1fr) auto;
  gap:13px;
}
.ldash__summary-image-wrap,
.ldash__summary-image-wrap img,
.ldash__summary-placeholder{
  width:58px;
  height:58px;
  border-radius:8px;
}
.ldash__summary-image-wrap>span{
  top:-7px;
  right:-7px;
  width:20px;
  height:20px;
  font-size:11px;
}
.ldash__summary-product-info strong{
  font-size:13px;
  line-height:1.45;
  font-weight:500;
}
.ldash__summary-product-info small{
  margin-top:4px;
  font-size:12px;
}
.ldash__summary-product-price{
  font-size:12px;
}
.ldash__summary-totals{
  gap:15px;
  padding-top:22px;
}
.ldash__summary-totals>div{
  font-size:13px;
}
.ldash__grand-total{
  margin-top:18px;
  padding-top:20px;
  font-size:16px;
  font-weight:650;
}
.ldash__grand-total strong{
  font-size:20px;
}
@media(max-width:980px){
  .ldash{max-width:none;padding:20px 18px 42px}
}
@media(max-width:760px){
  .ldash__tabs{margin-bottom:22px}
  .ldash__order-detail-grid{grid-template-columns:1fr}
  .ldash__info-grid{grid-template-columns:1fr}
  .ldash__detail-actions{width:auto}
}

</style>

<script>
document.addEventListener('DOMContentLoaded',function(){
  var tabs=document.querySelectorAll('.ldash__tab');
  var panels=document.querySelectorAll('.ldash__panel');
  tabs.forEach(function(tab){tab.addEventListener('click',function(){
    tabs.forEach(function(t){t.classList.remove('is-active')});
    panels.forEach(function(p){p.classList.remove('is-active')});
    tab.classList.add('is-active');
    var panel=document.getElementById('ldash-'+tab.dataset.tab);if(panel)panel.classList.add('is-active');
    if(tab.dataset.tab==='recent')renderRecent();
  })});
  function esc(v){return String(v||'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]})}
  function renderRecent(){var box=document.getElementById('ldash-recent-grid'),items=[];try{items=JSON.parse(localStorage.getItem('recently_viewed_products')||'[]')}catch(e){}if(!items.length){box.innerHTML='<p class="ldash__muted">No recently viewed products found.</p>';return}box.innerHTML=items.slice(0,8).map(function(p){return '<article class="ldash__product"><a href="'+esc(p.url)+'">'+(p.image?'<img src="'+esc(p.image)+'" alt="'+esc(p.title)+'">':'')+'<h3>'+esc(p.title)+'</h3><strong>'+esc(p.price)+'</strong></a></article>'}).join('')}
});
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>function ldashDownloadInvoice(invoiceId,orderName){var invoice=document.getElementById(invoiceId);if(!invoice){alert('Invoice data was not found.');return}if(typeof html2pdf==='undefined'){alert('Invoice library failed to load. Please refresh and try again.');return}var wrapper=document.createElement('div');wrapper.appendChild(invoice.firstElementChild.cloneNode(true));var clean=String(orderName||'invoice').replace('#','').replace(/[^a-zA-Z0-9-_]/g,'-');html2pdf().set({margin:8,filename:clean+'-invoice.pdf',image:{type:'jpeg',quality:.98},html2canvas:{scale:2,useCORS:true,backgroundColor:'#ffffff'},jsPDF:{unit:'mm',format:'a4',orientation:'portrait'}}).from(wrapper).save()}function ldashReorder(items){if(!Array.isArray(items)||!items.length){alert('No products were found in this order.');return}fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items:items})}).then(function(r){if(!r.ok)throw new Error();return r.json()}).then(function(){window.location.href='/cart'}).catch(function(){alert('Some products are unavailable. Please try again.')})}</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  var dashboard = document.querySelector('.ldash');
  var tabsBox = document.querySelector('.ldash__tabs');
  var panels = document.querySelectorAll('.ldash__panel');
  var detailWrap = document.getElementById('ldash-order-detail');

  function showOrder(id) {
    var target = document.getElementById('ldash-order-' + id);
    if (!target || !detailWrap) return;

    panels.forEach(function (panel) {
      panel.classList.remove('is-active');
      panel.style.display = 'none';
    });

    detailWrap.hidden = false;
    detailWrap.style.display = 'block';

    detailWrap.querySelectorAll('.ldash__order-detail').forEach(function (detail) {
      detail.hidden = true;
      detail.style.display = 'none';
    });

    target.hidden = false;
    target.style.display = 'block';

    if (dashboard) dashboard.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function closeOrder() {
    if (detailWrap) {
      detailWrap.hidden = true;
      detailWrap.style.display = 'none';
    }

    detailWrap && detailWrap.querySelectorAll('.ldash__order-detail').forEach(function (detail) {
      detail.hidden = true;
      detail.style.display = 'none';
    });

    panels.forEach(function (panel) {
      panel.style.display = '';
      panel.classList.remove('is-active');
    });

    document.querySelectorAll('.ldash__tab').forEach(function (tab) {
      tab.classList.remove('is-active');
    });

    var ordersPanel = document.getElementById('ldash-orders');
    var ordersTab = document.querySelector('.ldash__tab[data-tab="orders"]');
    if (ordersPanel) ordersPanel.classList.add('is-active');
    if (ordersTab) ordersTab.classList.add('is-active');

    history.replaceState(null, '', window.location.pathname);
    if (dashboard) dashboard.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  document.addEventListener('click', function (event) {
    var viewLink = event.target.closest('.ldash-view-order');
    if (viewLink) {
      event.preventDefault();
      var id = viewLink.getAttribute('data-order-id');
      history.pushState({ orderId: id }, '', window.location.pathname + '#order-' + id);
      showOrder(id);
      return;
    }

    var backButton = event.target.closest('[data-order-back]');
    if (backButton) {
      event.preventDefault();
      closeOrder();
    }
  });

  window.addEventListener('hashchange', function () {
    var match = window.location.hash.match(/^#order-(.+)$/);
    if (match) showOrder(match[1]);
    else closeOrder();
  });

  var initialMatch = window.location.hash.match(/^#order-(.+)$/);
  if (initialMatch) showOrder(initialMatch[1]);
});
</script>
{% endif %}
