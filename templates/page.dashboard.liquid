{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign customer_name = customer.metafields.custom.full_name.value | default: customer.metafields.custom.full_name | default: customer.name
  assign customer_email = customer.metafields.custom.email.value | default: customer.metafields.custom.email | default: customer.email
  assign customer_phone = customer.metafields.custom.phone.value | default: customer.metafields.custom.phone | default: customer.phone
-%}

{% unless customer %}
  <script>window.location.replace('/customer_authentication/login?return_to=%2Fpages%2Fdashboard');</script>
{% endunless %}

{% if customer %}
<div class="ldash">
  <div class="ldash__head">
    <h1>Welcome, {{ customer.first_name | default: customer.name }}!</h1>
    <a href="{{ routes.account_logout_url }}" class="ldash__logout">
      <svg viewBox="0 0 24 24"><path d="M10 5H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h4M15 8l4 4-4 4M9 12h10"/></svg>
      Logout
    </a>
  </div>

  <div class="ldash__tabs" role="tablist">
    <button class="ldash__tab is-active" data-tab="profile" type="button">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c0-4 2.8-7 7-7s7 3 7 7"/></svg>
      My profile
    </button>
    <button class="ldash__tab" data-tab="orders" type="button">
      <svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg>
      Orders
    </button>
    <button class="ldash__tab" data-tab="addresses" type="button">
      <svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>
      Addresses
    </button>
    <button class="ldash__tab" data-tab="recent" type="button">
      <svg viewBox="0 0 24 24"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg>
      Recently viewed
    </button>
    <button class="ldash__tab" data-tab="top" type="button">
      <svg viewBox="0 0 24 24"><path d="M12 3v18M7 8l5-5 5 5M6 16h12"/></svg>
      Top ordered products
    </button>
  </div>

  <div id="ldash-profile" class="ldash__panel is-active">
    <div class="ldash__grid">
      <article class="ldash__card">
        <header class="ldash__card-head">
          <h2><span><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c0-4 2.8-7 7-7s7 3 7 7"/></svg></span>Account Details</h2>
          <a href="https://account.lymko.in/profile" class="ldash__edit" title="Edit profile">
            <svg viewBox="0 0 24 24"><path d="m4 20 4.5-1 10-10-3.5-3.5-10 10L4 20Z"/><path d="m13.5 6.5 3.5 3.5"/></svg>
          </a>
        </header>
        <div class="ldash__card-body">
          <p class="ldash__detail"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M5 20c0-4 2.8-7 7-7s7 3 7 7"/></svg>{{ customer_name }}</p>
          {% if customer_phone != blank %}<p class="ldash__detail"><svg viewBox="0 0 24 24"><path d="M7 3h3l1 5-2 1c1.2 2.8 3.4 5 6.2 6.2l1-2 4.8 1V17c0 2.2-1.8 4-4 4C9.3 21 3 14.7 3 7c0-2.2 1.8-4 4-4Z"/></svg>{{ customer_phone }}</p>{% endif %}
          <p class="ldash__detail"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>{{ customer_email }}</p>
        </div>
      </article>

      <article class="ldash__card">
        <header class="ldash__card-head">
          <h2><span><svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg></span>Default Address</h2>
          <a href="https://account.lymko.in/profile" class="ldash__text-link">View all</a>
        </header>
        <div class="ldash__card-body">
          {% if customer.default_address %}
            <div class="ldash__address">{{ customer.default_address | format_address }}</div>
          {% else %}
            <div class="ldash__empty-address">
              <svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>
              <span>No addresses added</span>
              <a href="https://account.lymko.in/profile" class="ldash__small-btn">Add</a>
            </div>
          {% endif %}
        </div>
      </article>
    </div>

    <article class="ldash__card ldash__orders-card">
      <header class="ldash__card-head">
        <h2><span><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>Recent Orders</h2>
      </header>
      <div class="ldash__card-body">
        
        {% if customer.orders.size > 0 %}
          <div class="ldash__order-list">
            {% for order in customer.orders limit: 3 %}
              <div class="ldash__order-row">
                <div>
                  <strong>{{ order.name }}</strong>
                  <span>{{ order.created_at | date: "%d %b %Y" }}</span>
                </div>
                <div>
                  <strong>{{ order.total_price | money }}</strong>
                  <a href="{{ order.customer_url }}">View details</a>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="ldash__empty-orders">
            <div class="ldash__bag"><svg viewBox="0 0 64 64"><circle cx="32" cy="32" r="27"/><path d="M22 25h20l-2 20H24l-2-20Z"/><path d="M27 25a5 5 0 0 1 10 0"/><path d="M45 18v8M41 22h8"/></svg></div>
            <h3>You haven't placed any orders yet.</h3>
            <p>Looks like you haven't ordered anything from us yet. Explore our collections and find something you'll love.</p>
            <a href="{{ routes.collections_url }}" class="ldash__primary">Explore Collections</a>
          </div>
        {% endif %}

        <div class="ldash__trust">
          <div><strong>Secure Checkout</strong><span>Safe and protected payments.</span></div>
          <div><strong>Fast Delivery</strong><span>Quick updates on every order.</span></div>
          <div><strong>24/7 Support</strong><span>Help whenever you need it.</span></div>
        </div>
      </div>
    </article>
  </div>

  <div id="ldash-orders" class="ldash__panel">
    <article class="ldash__card">
      <header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M4 7h16l-1 12H5L4 7Z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg></span>Order History</h2></header>
      <div class="ldash__card-body">
        {% paginate customer.orders by 10 %}
          {% if customer.orders.size > 0 %}
            <div class="ldash__table-wrap"><table class="ldash__table"><thead><tr><th>Order</th><th>Date</th><th>Payment</th><th>Fulfillment</th><th>Total</th><th></th></tr></thead><tbody>
            {% for order in customer.orders %}<tr><td>{{ order.name }}</td><td>{{ order.created_at | date: "%d %b %Y" }}</td><td>{{ order.financial_status_label }}</td><td>{{ order.fulfillment_status_label }}</td><td>{{ order.total_price | money }}</td><td><a href="{{ order.customer_url }}">View</a></td></tr>{% endfor %}
            </tbody></table></div>
            {% if paginate.pages > 1 %}<div class="ldash__pagination">{{ paginate | default_pagination }}</div>{% endif %}
          {% else %}<p class="ldash__muted">No orders found.</p>{% endif %}
        {% endpaginate %}
      </div>
    </article>
  </div>

  <div id="ldash-addresses" class="ldash__panel">
    <article class="ldash__card">
      <header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M12 21s6-5.4 6-11a6 6 0 1 0-12 0c0 5.6 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg></span>Saved Addresses</h2><a href="https://account.lymko.in/profile" class="ldash__small-btn">Add</a></header>
      <div class="ldash__card-body">
        {% if customer.addresses.size > 0 %}<div class="ldash__address-grid">{% for address in customer.addresses %}<div class="ldash__address-card">{% if address == customer.default_address %}<span>Default</span>{% endif %}{{ address | format_address }}</div>{% endfor %}</div>{% else %}<p class="ldash__muted">No addresses added.</p>{% endif %}
      </div>
    </article>
  </div>

  <div id="ldash-recent" class="ldash__panel">
    <article class="ldash__card"><header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg></span>Recently Viewed Products</h2></header><div class="ldash__card-body"><div class="ldash__products" id="ldash-recent-grid"><p class="ldash__muted">No recently viewed products found.</p></div></div></article>
  </div>

  <div id="ldash-top" class="ldash__panel">
    <article class="ldash__card"><header class="ldash__card-head"><h2><span><svg viewBox="0 0 24 24"><path d="M12 3v18M7 8l5-5 5 5M6 16h12"/></svg></span>Top Ordered Products</h2></header><div class="ldash__card-body"><p class="ldash__muted">Your frequently ordered products will appear here.</p></div></article>
  </div>
</div>

<style>
.ldash{--p:#6f3cff;--ps:#f1edff;--b:#ececf1;--m:#6c7280;max-width:1280px;margin:auto;padding:28px 22px 60px;color:#111}.ldash *{box-sizing:border-box}.ldash svg{width:20px;height:20px;fill:none;stroke:currentColor;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}.ldash__head{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:26px}.ldash__head h1{margin:0;font-size:clamp(22px,2.4vw,34px)}.ldash__logout{display:flex;align-items:center;gap:8px;padding:10px 17px;border:1px solid #d9dbe2;border-radius:9px;color:#111;text-decoration:none}.ldash__tabs{display:flex;gap:8px;padding:12px 16px 0;margin-bottom:28px;overflow:auto;border:1px solid var(--b);border-radius:14px;background:#fff}.ldash__tab{position:relative;display:flex;align-items:center;gap:9px;white-space:nowrap;padding:0 16px 13px;min-height:50px;border:0;border-radius:8px 8px 0 0;background:transparent;color:#4e5563;cursor:pointer}.ldash__tab:after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:transparent}.ldash__tab.is-active{background:var(--ps);color:var(--p)}.ldash__tab.is-active:after{background:var(--p)}.ldash__panel{display:none}.ldash__panel.is-active{display:block}.ldash__grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.ldash__card{overflow:hidden;border:1px solid var(--b);border-radius:14px;background:#fff;box-shadow:0 5px 18px rgba(0,0,0,.035)}.ldash__card-head{min-height:72px;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--b)}.ldash__card-head h2{display:flex;align-items:center;gap:10px;margin:0;font-size:18px}.ldash__card-head h2 span{display:grid;place-items:center;width:34px;height:34px;border-radius:50%;background:var(--ps);color:var(--p)}.ldash__card-body{padding:22px}.ldash__edit,.ldash__text-link{color:#111;text-decoration:none}.ldash__detail{display:flex;align-items:center;gap:13px;margin:0 0 20px;font-size:15px}.ldash__detail:last-child{margin-bottom:0}.ldash__address address,.ldash__address-card address{font-style:normal;line-height:1.6}.ldash__empty-address{min-height:120px;display:flex;align-items:center;gap:14px}.ldash__empty-address>svg{width:46px;height:46px;padding:12px;border-radius:12px;background:#f7f7f9}.ldash__empty-address span{flex:1;color:var(--m)}.ldash__small-btn{display:inline-flex;align-items:center;justify-content:center;min-width:48px;height:38px;padding:0 14px;border:1px solid #dadce3;border-radius:10px;color:#111;text-decoration:none;background:#fff}.ldash__orders-card{margin-top:24px}.ldash__empty-orders{text-align:center;padding:34px 20px 24px}.ldash__bag{width:86px;height:86px;margin:0 auto 22px;color:var(--p)}.ldash__bag svg{width:86px;height:86px}.ldash__bag circle{fill:var(--ps);stroke:none}.ldash__empty-orders h3{margin:0 0 12px}.ldash__empty-orders p{max-width:620px;margin:0 auto 20px;color:var(--m);line-height:1.6}.ldash__primary{display:inline-flex;min-height:46px;padding:0 22px;align-items:center;border-radius:7px;background:#000;color:#fff;text-decoration:none}.ldash__trust{display:grid;grid-template-columns:repeat(3,1fr);margin-top:28px;border:1px solid #f2d0c7;border-radius:10px;overflow:hidden}.ldash__trust>div{padding:18px;text-align:center;background:#fffdfc}.ldash__trust>div+div{border-left:1px solid #f2d0c7}.ldash__trust strong,.ldash__trust span{display:block}.ldash__trust span{margin-top:5px;color:var(--m);font-size:12px}.ldash__order-list{display:grid;gap:14px}.ldash__order-row{display:flex;justify-content:space-between;padding:16px;border:1px solid var(--b);border-radius:12px}.ldash__order-row span,.ldash__order-row a{display:block;margin-top:5px}.ldash__order-row span{color:var(--m);font-size:13px}.ldash__order-row a{color:var(--p);text-decoration:none}.ldash__table-wrap{overflow:auto}.ldash__table{width:100%;border-collapse:collapse}.ldash__table th,.ldash__table td{padding:14px 12px;border-bottom:1px solid var(--b);text-align:left;white-space:nowrap}.ldash__table a{color:var(--p);text-decoration:none}.ldash__address-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.ldash__address-card{position:relative;min-height:160px;padding:20px;border:1px solid var(--b);border-radius:12px}.ldash__address-card>span{position:absolute;top:12px;right:12px;padding:4px 8px;border-radius:20px;background:var(--ps);color:var(--p);font-size:11px}.ldash__products{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.ldash__product{overflow:hidden;border:1px solid var(--b);border-radius:12px}.ldash__product a{color:inherit;text-decoration:none}.ldash__product img{width:100%;aspect-ratio:1;object-fit:cover}.ldash__product h3,.ldash__product strong{display:block;padding:0 14px}.ldash__product h3{font-size:14px}.ldash__product strong{padding-bottom:16px;color:var(--p)}.ldash__muted{color:var(--m)}
@media(max-width:900px){.ldash__grid,.ldash__address-grid{grid-template-columns:1fr}.ldash__products{grid-template-columns:repeat(2,1fr)}}
@media(max-width:640px){.ldash{padding:20px 12px 48px}.ldash__head{align-items:flex-start}.ldash__trust{grid-template-columns:1fr}.ldash__trust>div+div{border-left:0;border-top:1px solid #f2d0c7}.ldash__order-row{flex-direction:column;gap:12px}}
</style>

<script>
document.addEventListener('DOMContentLoaded',function(){
  var tabs=document.querySelectorAll('.ldash__tab');
  var panels=document.querySelectorAll('.ldash__panel');
  tabs.forEach(function(tab){tab.addEventListener('click',function(){
    tabs.forEach(function(t){t.classList.remove('is-active')});
    panels.forEach(function(p){p.classList.remove('is-active')});
    tab.classList.add('is-active');
    var panel=document.getElementById('ldash-'+tab.dataset.tab);if(panel)panel.classList.add('is-active');
    if(tab.dataset.tab==='recent')renderRecent();
  })});
  function esc(v){return String(v||'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]})}
  function renderRecent(){var box=document.getElementById('ldash-recent-grid'),items=[];try{items=JSON.parse(localStorage.getItem('recently_viewed_products')||'[]')}catch(e){}if(!items.length){box.innerHTML='<p class="ldash__muted">No recently viewed products found.</p>';return}box.innerHTML=items.slice(0,8).map(function(p){return '<article class="ldash__product"><a href="'+esc(p.url)+'">'+(p.image?'<img src="'+esc(p.image)+'" alt="'+esc(p.title)+'">':'')+'<h3>'+esc(p.title)+'</h3><strong>'+esc(p.price)+'</strong></a></article>'}).join('')}
});
</script>
{% endif %}
