{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign name_from_metafield = customer.metafields.custom.full_name.value | default: customer.metafields.custom.full_name | default: customer.name
  assign email_from_metafield = customer.metafields.custom.email.value | default: customer.metafields.custom.email | default: customer.email
  assign phone_from_metafield = customer.metafields.custom.phone.value | default: customer.metafields.custom.phone | default: customer.phone
  assign store_credit = customer.metafields.custom.store_credit.value | default: customer.metafields.custom.store_credit | default: "$0.00"
  assign cashback_balance = customer.metafields.custom.cashback.value | default: customer.metafields.custom.cashback | default: "$0.00"

  assign birth_date = customer.metafields.facts.birth_date.value | default: customer.metafields.facts.birth_date
  assign pin_code = customer.metafields.custom.pin_code.value | default: customer.metafields.custom.pin_code
  assign state = customer.metafields.custom.state.value | default: customer.metafields.custom.state
  assign city = customer.metafields.custom.city.value | default: customer.metafields.custom.city
  assign address = customer.metafields.custom.address.value | default: customer.metafields.custom.address
  assign gender = customer.metafields.custom.gender.value | default: customer.metafields.custom.gender
-%}

<div class="customer account dashboard-container">
  {% if customer %}
    <!-- Dashboard Header -->
    <div class="dashboard-header">
      <div>
        <h1>Welcome, <span class="accent-name">{{ customer.first_name }}</span>!</h1>
      </div>
      <a href="{{ routes.account_logout_url }}" class="logout-btn">
        <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" fill="none" viewBox="0 0 18 19">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M6 4.5a3 3 0 116 0 3 3 0 01-6 0zm3-4a4 4 0 100 8 4 4 0 000-8zm5.58 12.15c1.12.82 1.83 2.24 1.91 4.85H1.51c.08-2.6.79-4.03 1.9-4.85C4.66 11.75 6.5 11.5 9 11.5s4.35.26 5.58 1.15zM9 10.5c-2.5 0-4.65.24-6.17 1.35C1.27 12.98.5 14.93.5 18v.5h17V18c0-3.07-.77-5.02-2.33-6.15-1.52-1.1-3.67-1.35-6.17-1.35z" fill="currentColor"></path>
        </svg>
        Logout
      </a>
    </div>

    <!-- Dashboard Tabs -->
    <div class="tabs-scroll-wrapper">
      <div class="dashboard-tabs">
        <button class="tab-button active" onclick="switchTab(event, 'profile')">
          <span class="tab-icon">👤</span> My profile
        </button>
        <button class="tab-button" onclick="switchTab(event, 'orders')">
          <span class="tab-icon">📦</span> Orders
        </button>
        <button class="tab-button" onclick="switchTab(event, 'cashback')">
          <span class="tab-icon">💰</span> Cashback
        </button>
        <button class="tab-button" onclick="switchTab(event, 'addresses')">
          <span class="tab-icon">📍</span> Addresses
        </button>
        <button class="tab-button" onclick="switchTab(event, 'recently-viewed')">
          <span class="tab-icon">👁️</span> Recently viewed
        </button>
        <button class="tab-button" onclick="switchTab(event, 'top-products')">
          <span class="tab-icon">🔥</span> Top ordered products
        </button>
      </div>
    </div>

    <!-- Tab Contents -->
    <div class="tab-contents-wrapper">
      
      <!-- 1. MY PROFILE TAB -->
      <div id="tab-profile" class="tab-content active">
        <div class="profile-grid">
          <!-- Account Details Card -->
          <div class="dashboard-card card-half">
            <div class="card-header">
              <h2>
                <span class="card-icon">👤</span> Account Details
              </h2>
              <a href="{{ routes.account_url }}" class="card-action-link" title="Edit Profile">✏️</a>
            </div>
            <div class="card-body font-details">
              <p class="detail-item"><strong>Name:</strong> {{ name_from_metafield }}</p>
              <p class="detail-item"><strong>Email:</strong> {{ email_from_metafield }}</p>
              {% if phone_from_metafield != blank %}
                <p class="detail-item"><strong>Phone:</strong> {{ phone_from_metafield }}</p>
              {% endif %}
              {% if gender != blank %}
                <p class="detail-item"><strong>Gender:</strong> {{ gender }}</p>
              {% endif %}
              {% if birth_date != blank %}
                <p class="detail-item"><strong>Birth Date:</strong> {{ birth_date }}</p>
              {% endif %}
              {% if address != blank %}
                <p class="detail-item"><strong>Address:</strong> {{ address }}</p>
              {% endif %}
              {% if city != blank %}
                <p class="detail-item"><strong>City:</strong> {{ city }}</p>
              {% endif %}
              {% if state != blank %}
                <p class="detail-item"><strong>State:</strong> {{ state }}</p>
              {% endif %}
              {% if pin_code != blank %}
                <p class="detail-item"><strong>Pin Code:</strong> {{ pin_code }}</p>
              {% endif %}
              <div class="store-credit-box">
                <span class="credit-icon">💵</span>
                <span><strong>{{ store_credit }}</strong> Store credit</span>
              </div>
            </div>
          </div>

          <!-- Default Address Card -->
          <div class="dashboard-card card-half">
            <div class="card-header">
              <h2>
                <span class="card-icon">📍</span> Default Address
              </h2>
              <a href="{{ routes.account_addresses_url }}" class="card-action-link">View all</a>
            </div>
            <div class="card-body">
              {% if customer.default_address %}
                <div class="address-details">
                  {{ customer.default_address | format_address }}
                </div>
              {% else %}
                <p class="no-data-msg">No default address saved yet.</p>
                <a href="{{ routes.account_addresses_url }}" class="btn-outline-mini">Add address</a>
              {% endif %}
            </div>
          </div>
        </div>

        <!-- Recent Orders Card -->
        <div class="dashboard-card card-full margin-top-2">
          <div class="card-header">
            <h2>
              <span class="card-icon">🕒</span> Recent Orders
            </h2>
            <button class="card-action-link-btn" onclick="triggerTab('orders')">View all orders</button>
          </div>
          <div class="card-body">
            {%- assign recent_orders = customer.orders -%}
            {%- if recent_orders.size > 0 -%}
              <div class="recent-orders-list">
                {%- for order in recent_orders limit: 3 -%}
                  <div class="recent-order-row">
                    <div class="order-img-desc">
                      <div class="order-thumbnail">
                        {%- if order.line_items.first.image -%}
                          <img src="{{ order.line_items.first.image | image_url: width: 80, height: 80, crop: 'center' }}" alt="{{ order.line_items.first.title }}" loading="lazy">
                        {%- else -%}
                          <div class="placeholder-img">📦</div>
                        {%- endif -%}
                      </div>
                      <div class="order-meta">
                        <span class="order-number">{{ order.name }}</span>
                        <span class="order-date">{{ order.created_at | date: "%B %d, %Y" }}</span>
                      </div>
                    </div>
                    
                    <div class="order-status-badges">
                      <span class="status-badge payment-{{ order.financial_status }}">
                        {{ order.financial_status_label }}
                      </span>
                      <span class="status-badge fulfillment-{{ order.fulfillment_status }}">
                        {{ order.fulfillment_status_label }}
                      </span>
                    </div>

                    <div class="order-price-count">
                      <span class="order-price">{{ order.total_price | money }}</span>
                      <span class="order-count">{{ order.item_count }} {% if order.item_count == 1 %}item{% else %}items{% endif %}</span>
                    </div>

                    <div class="order-actions">
                      <a href="{{ order.customer_url }}" class="btn-view-details">View details</a>
                      {% capture items_json %}
                        [
                          {% for line_item in order.line_items %}
                            {
                              "variant_id": {{ line_item.variant_id }},
                              "quantity": {{ line_item.quantity }}
                            }{% unless forloop.last %},{% endunless %}
                          {% endfor %}
                        ]
                      {% endcapture %}
                      <button class="btn-reorder" onclick='reorderItems({{ items_json }})'>Reorder</button>
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- else -%}
              <p class="no-data-msg">You haven't placed any orders yet.</p>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- 2. ORDERS TAB -->
      <div id="tab-orders" class="tab-content">
        <div class="dashboard-card card-full">
          <div class="card-header">
            <h2>📦 Order History</h2>
          </div>
          <div class="card-body">
            {% paginate customer.orders by 10 %}
              {%- if customer.orders.size > 0 -%}
                <div class="table-responsive">
                  <table class="dashboard-orders-table">
                    <thead>
                      <tr>
                        <th>Order</th>
                        <th>Date</th>
                        <th>Payment Status</th>
                        <th>Fulfillment</th>
                        <th>Total</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {%- for order in customer.orders -%}
                        <tr>
                          <td data-label="Order">
                            <a href="{{ order.customer_url }}" class="order-link-title">{{ order.name }}</a>
                          </td>
                          <td data-label="Date">{{ order.created_at | date: "%b %d, %Y" }}</td>
                          <td data-label="Payment Status">
                            <span class="status-badge payment-{{ order.financial_status }}">
                              {{ order.financial_status_label }}
                            </span>
                          </td>
                          <td data-label="Fulfillment">
                            <span class="status-badge fulfillment-{{ order.fulfillment_status }}">
                              {{ order.fulfillment_status_label }}
                            </span>
                          </td>
                          <td data-label="Total">{{ order.total_price | money }}</td>
                          <td data-label="Actions">
                            <div class="table-actions">
                              <a href="{{ order.customer_url }}" class="btn-view-details-mini">View</a>
                              {% capture items_json %}
                                [
                                  {% for line_item in order.line_items %}
                                    {
                                      "variant_id": {{ line_item.variant_id }},
                                      "quantity": {{ line_item.quantity }}
                                    }{% unless forloop.last %},{% endunless %}
                                  {% endfor %}
                                ]
                              {% endcapture %}
                              <button class="btn-reorder-mini" onclick='reorderItems({{ items_json }})'>Reorder</button>
                            </div>
                          </td>
                        </tr>
                      {%- endfor -%}
                    </tbody>
                  </table>
                </div>

                {%- if paginate.pages > 1 -%}
                  <div class="pagination-wrapper">
                    {{ paginate | default_pagination }}
                  </div>
                {%- endif -%}
              {%- else -%}
                <p class="no-data-msg">No orders found.</p>
              {%- endif -%}
            {% endpaginate %}
          </div>
        </div>
      </div>

      <!-- 3. CASHBACK TAB -->
      <div id="tab-cashback" class="tab-content">
        <div class="dashboard-card card-full">
          <div class="card-header">
            <h2>💰 Cashback Details</h2>
          </div>
          <div class="card-body">
            <div class="cashback-banner">
              <div class="cashback-wallet">
                <span class="wallet-icon">👛</span>
                <div class="wallet-text">
                  <h3>Available Cashback</h3>
                  <span class="cashback-amount">{{ cashback_balance }}</span>
                </div>
              </div>
              <p class="cashback-promo">Earn cashback on every purchase! Your balance is automatically applied as store credit at checkout.</p>
            </div>
            
            <h3 class="section-sub-title">How it works</h3>
            <div class="cashback-steps-grid">
              <div class="step-item">
                <span class="step-num">1</span>
                <h4>Shop products</h4>
                <p>Purchase any qualifying items in our catalog to accumulate rewards.</p>
              </div>
              <div class="step-item">
                <span class="step-num">2</span>
                <h4>Earn balance</h4>
                <p>Once your order is processed, your cashback balance will update automatically.</p>
              </div>
              <div class="step-item">
                <span class="step-num">3</span>
                <h4>Redeem instantly</h4>
                <p>Apply your store credit on subsequent orders directly at the cart page.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 4. ADDRESSES TAB -->
      <div id="tab-addresses" class="tab-content">
        <div class="dashboard-card card-full">
          <div class="card-header">
            <h2>📍 Saved Addresses</h2>
            <a href="{{ routes.account_addresses_url }}" class="btn-primary-mini">Manage Addresses</a>
          </div>
          <div class="card-body">
            {%- if customer.addresses.size > 0 -%}
              <div class="addresses-grid">
                {%- for address in customer.addresses -%}
                  <div class="address-card {% if address == customer.default_address %}is-default{% endif %}">
                    {%- if address == customer.default_address -%}
                      <span class="default-badge">Default</span>
                    {%- endif -%}
                    <div class="address-details-body">
                      {{ address | format_address }}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- else -%}
              <p class="no-data-msg">No saved addresses found.</p>
              <a href="{{ routes.account_addresses_url }}" class="btn-outline-mini">Add New Address</a>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- 5. RECENTLY VIEWED TAB -->
      <div id="tab-recently-viewed" class="tab-content">
        <div class="dashboard-card card-full">
          <div class="card-header">
            <h2>👁️ Recently Viewed Products</h2>
          </div>
          <div class="card-body">
            <div id="recently-viewed-grid" class="products-grid-dashboard">
              <p class="loading-products-msg">Loading recently viewed products...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 6. TOP ORDERED PRODUCTS TAB -->
      <div id="tab-top-products" class="tab-content">
        <div class="dashboard-card card-full">
          <div class="card-header">
            <h2>🔥 Your Frequently Ordered Products</h2>
          </div>
          <div class="card-body">
            {%- assign unique_ordered_products = "" -%}
            {%- for order in customer.orders -%}
              {%- for line_item in order.line_items -%}
                {%- if line_item.product -%}
                  {%- unless unique_ordered_products contains line_item.product.handle -%}
                    {%- assign unique_ordered_products = unique_ordered_products | append: line_item.product.handle | append: "," -%}
                  {%- endunless -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
            
            {%- assign product_handles = unique_ordered_products | split: "," -%}
            
            {%- if product_handles.size > 0 -%}
              <div class="products-grid-dashboard">
                {%- for handle in product_handles limit: 8 -%}
                  {%- assign ordered_product = all_products[handle] -%}
                  {%- if ordered_product != blank -%}
                    <div class="dashboard-product-card">
                      <div class="prod-card-image">
                        <img src="{{ ordered_product.featured_image | image_url: width: 240, height: 240, crop: 'center' }}" alt="{{ ordered_product.title }}" loading="lazy">
                      </div>
                      <div class="prod-card-body">
                        <h3>{{ ordered_product.title }}</h3>
                        <span class="prod-card-price">{{ ordered_product.price | money }}</span>
                        <a href="{{ ordered_product.url }}" class="btn-buy-now-prod">View Product</a>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- else -%}
              <p class="no-data-msg">You haven't ordered any products yet.</p>
            {%- endif -%}
          </div>
        </div>
      </div>

    </div>
  {% else %}
    <script>
      window.location.href = '/account/login?return_to=' + window.location.pathname;
    </script>
  {% endif %}
</div>

<!-- Premium Dashboard Styles -->
<style>
  :root {
    --dash-bg: #f9fbfc;
    --dash-card-bg: #ffffff;
    --dash-text: #2c3e50;
    --dash-accent: #2e7d32; /* Rich Forest Green */
    --dash-accent-hover: #1b5e20;
    --dash-border: #eaedf1;
    --dash-badge-bg: #e8f5e9;
    --dash-badge-text: #2e7d32;
    --dash-shadow: 0px 8px 30px rgba(0, 0, 0, 0.04);
  }

  .dashboard-container {
    background-color: var(--dash-bg);
    min-height: 80vh;
    padding: 3rem 1.5rem;
    font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--dash-text);
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
  }

  .dashboard-header h1 {
    font-size: 2.4rem;
    font-weight: 700;
    margin: 0;
    color: #1e293b;
  }

  .dashboard-header .accent-name {
    color: var(--dash-accent);
    position: relative;
  }

  .logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 30px;
    background-color: white;
    border: 1px solid #cbd5e1;
    color: #64748b;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .logout-btn svg {
    width: 15px;
    height: 15px;
  }

  .logout-btn:hover {
    color: #ef4444;
    border-color: #fca5a5;
    background-color: #fef2f2;
    transform: translateY(-1px);
  }

  /* Horizontal Scroll Tabs */
  .tabs-scroll-wrapper {
    overflow-x: auto;
    margin-bottom: 2.5rem;
    padding-bottom: 5px;
    -webkit-overflow-scrolling: touch;
  }

  .tabs-scroll-wrapper::-webkit-scrollbar {
    height: 4px;
  }

  .tabs-scroll-wrapper::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 4px;
  }

  .dashboard-tabs {
    display: flex;
    gap: 12px;
    width: max-content;
    padding: 2px;
  }

  .tab-button {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 30px;
    border: 1px solid #e2e8f0;
    background: white;
    color: #64748b;
    font-size: 1.45rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tab-button:hover {
    border-color: #cbd5e1;
    color: #1e293b;
    background-color: #f8fafc;
  }

  .tab-button.active {
    background-color: var(--dash-badge-bg);
    color: var(--dash-badge-text);
    border-color: var(--dash-accent);
    box-shadow: 0px 4px 10px rgba(46, 125, 50, 0.1);
  }

  /* Tab Contents */
  .tab-content {
    display: none;
    animation: fadeIn 0.4s ease-out;
  }

  .tab-content.active {
    display: block;
  }

  /* Cards Grid */
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.8rem;
  }

  @media screen and (max-width: 768px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
  }

  .dashboard-card {
    background: var(--dash-card-bg);
    border-radius: 16px;
    border: 1px solid var(--dash-border);
    box-shadow: var(--dash-shadow);
    padding: 2rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .dashboard-card:hover {
    transform: translateY(-2px);
    box-shadow: 0px 12px 35px rgba(0, 0, 0, 0.06);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--dash-border);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
  }

  .card-header h2 {
    font-size: 1.6rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .card-action-link {
    color: var(--dash-accent);
    text-decoration: none;
    font-size: 1.35rem;
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .card-action-link:hover {
    color: var(--dash-accent-hover);
    text-decoration: underline;
  }

  .card-action-link-btn {
    border: none;
    background: transparent;
    color: var(--dash-accent);
    cursor: pointer;
    font-size: 1.35rem;
    font-weight: 500;
  }

  .card-action-link-btn:hover {
    text-decoration: underline;
    color: var(--dash-accent-hover);
  }

  /* Account Details styling */
  .font-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-item {
    margin: 0;
    font-size: 1.45rem;
    color: #475569;
  }

  .store-credit-box {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    padding: 10px 14px;
    background-color: #f0fdf4;
    border: 1px dashed var(--dash-accent);
    border-radius: 8px;
    color: var(--dash-accent);
    font-size: 1.45rem;
    width: fit-content;
  }

  /* Default Address layout */
  .address-details address {
    font-style: normal;
    line-height: 1.6;
    color: #475569;
    font-size: 1.45rem;
  }

  .no-data-msg {
    color: #94a3b8;
    margin: 1.5rem 0;
    font-size: 1.4rem;
  }

  .btn-outline-mini {
    display: inline-block;
    padding: 8px 16px;
    border: 1px solid var(--dash-accent);
    border-radius: 20px;
    color: var(--dash-accent);
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-outline-mini:hover {
    background-color: var(--dash-accent);
    color: white;
  }

  /* Recent Orders layout */
  .recent-orders-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .recent-order-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--dash-border);
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .recent-order-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .order-img-desc {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
    min-width: 250px;
  }

  .order-thumbnail img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--dash-border);
  }

  .placeholder-img {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    background-color: #f1f5f9;
    border-radius: 8px;
  }

  .order-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .order-number {
    font-weight: 600;
    font-size: 1.5rem;
    color: #1e293b;
  }

  .order-date {
    font-size: 1.3rem;
    color: #94a3b8;
  }

  /* Badges */
