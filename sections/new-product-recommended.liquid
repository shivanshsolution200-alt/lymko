{% assign section_id = section.id %}

<div id="recommended-{{ section_id }}" class="recommended-section">
  <div class="page-width">

    <!-- Heading -->
    <h2 class="single-heading">
      {{ section.settings.heading }}
    </h2>

    <!-- Products -->
    <div class="single-product-grid">
      {% if recommendations.performed and recommendations.products_count > 0 %}
        
        {% for product in recommendations.products limit: 4 %}
         {% render 'card-product-2',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_quick_add: settings.enable_quickadd,
              show_quick_view: settings.enable_quickview,
              show_new_tag: section.settings.show_new_tag,
              section_id: section.id
            %}
        {% endfor %}

      {% endif %}
    </div>

  </div>
</div>

<!-- AJAX LOAD FOR RECOMMENDATIONS -->
<script>
document.addEventListener("DOMContentLoaded", function() {
  const section = document.querySelector("#recommended-{{ section_id }}");

  fetch(window.Shopify.routes.root + "recommendations/products?product_id={{ product.id }}&limit=4&section_id={{ section_id }}")
    .then(res => res.text())
    .then(html => {
      const div = document.createElement("div");
      div.innerHTML = html;

      const newContent = div.querySelector("#recommended-{{ section_id }}");
      if (newContent) {
        section.innerHTML = newContent.innerHTML;
      }
    });
});
</script>

<style>

/* SECTION */
#recommended-{{ section_id }} {
  padding: 40px 0;
}

/* HEADING */
#recommended-{{ section_id }} .single-heading {
  text-align: center;
  margin-bottom: 25px;
}

/* GRID */
#recommended-{{ section_id }} .single-product-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

/* 🔥 ALWAYS SHOW ICONS */
#recommended-{{ section_id }} .product-icons,
#recommended-{{ section_id }} .product-icons li,
#recommended-{{ section_id }} .product-icons li a {
  opacity: 1 !important;
  visibility: visible !important;
  transform: none !important;
  pointer-events: auto !important;
}

/* POSITION ICONS PROPERLY */
#recommended-{{ section_id }} .product-icons {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 5;
}

/* REMOVE HOVER DEPENDENCY */
#recommended-{{ section_id }} .card:hover .product-icons {
  opacity: 1 !important;
  visibility: visible !important;
}

/* MOBILE */
@media (max-width: 768px) {
  #recommended-{{ section_id }} .single-product-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

</style>

{% schema %}
{
  "name": "New Recommended Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    }
  ],
  "presets": [
    {
      "name": "New Recommended Products"
    }
  ]
}
{% endschema %}