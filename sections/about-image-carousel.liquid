{% comment %}
  Section: About Image Carousel
  File: sections/about-image-carousel.liquid
{% endcomment %}

<section id="about-carousel-{{ section.id }}" class="about-carousel-section">
  <div class="about-carousel page-width" data-about-carousel="{{ section.id }}">
    <div class="about-carousel__viewport">
      <div class="about-carousel__track">
        {% for block in section.blocks %}
          <article class="about-carousel__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
            <div class="about-carousel__media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 2200
                  | image_tag:
                    class: 'about-carousel__image',
                    loading: 'lazy',
                    widths: '750, 1100, 1500, 1800, 2200',
                    sizes: '(max-width: 749px) 88vw, 74vw',
                    alt: block.settings.heading
                }}
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'about-carousel__placeholder' }}
              {% endif %}

              <div class="about-carousel__overlay"></div>

              <div class="about-carousel__content">
                {% if block.settings.eyebrow != blank %}
                  <div class="about-carousel__eyebrow">{{ block.settings.eyebrow }}</div>
                {% endif %}

                {% if block.settings.heading != blank %}
                  <h2 class="about-carousel__heading">{{ block.settings.heading }}</h2>
                {% endif %}

                {% if block.settings.button_label != blank %}
                  <a href="{{ block.settings.button_link | default: '#' }}" class="about-carousel__button">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

    {% if section.blocks.size > 1 %}
      <div class="about-carousel__dots">
        {% for block in section.blocks %}
          <button
            type="button"
            class="about-carousel__dot{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #about-carousel-{{ section.id }} {
    overflow: hidden;
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #about-carousel-{{ section.id }} * {
    box-sizing: border-box;
  }

  #about-carousel-{{ section.id }} .about-carousel {
    overflow: visible;
  }

  #about-carousel-{{ section.id }} .about-carousel__viewport {
    overflow: visible;
  }

  #about-carousel-{{ section.id }} .about-carousel__track {
    display: flex;
    align-items: stretch;
    gap: 10px;
    transition: transform .6s cubic-bezier(.22,.61,.36,1);
    will-change: transform;
  }

  #about-carousel-{{ section.id }} .about-carousel__slide {
    flex: 0 0 74%;
    min-width: 0;
    opacity: .55;
    transition: opacity .35s ease;
  }

  #about-carousel-{{ section.id }} .about-carousel__slide.is-active {
    opacity: 1;
  }

  #about-carousel-{{ section.id }} .about-carousel__media {
    position: relative;
    overflow: hidden;
    height: {{ section.settings.desktop_height }}px;
    border-radius: {{ section.settings.border_radius }}px;
    background: #e5e8ea;
  }

  #about-carousel-{{ section.id }} .about-carousel__image,
  #about-carousel-{{ section.id }} .about-carousel__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #about-carousel-{{ section.id }} .about-carousel__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0,0,0,0.12) 55%,
      rgba(0,0,0,0) 100%
    );
  }

  #about-carousel-{{ section.id }} .about-carousel__content {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: 8%;
    width: min(46%, 560px);
    color: {{ section.settings.text_color }};
    transform: translateY(-50%);
  }

  #about-carousel-{{ section.id }} .about-carousel__eyebrow {
    margin-bottom: 24px;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
  }

  #about-carousel-{{ section.id }} .about-carousel__heading {
    margin: 0;
    color: inherit;
    font-size: clamp(38px, 3vw, 58px);
    font-weight: 500;
    letter-spacing: -2px;
    line-height: 1.05;
  }

  #about-carousel-{{ section.id }} .about-carousel__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 156px;
    min-height: 48px;
    margin-top: 38px;
    padding: 12px 28px;
    color: #111;
    background: #fff;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
  }

  #about-carousel-{{ section.id }} .about-carousel__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 28px;
  }

  #about-carousel-{{ section.id }} .about-carousel__dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: #d0d0d0;
    cursor: pointer;
    transition: width .25s ease, background-color .25s ease;
  }

  #about-carousel-{{ section.id }} .about-carousel__dot.is-active {
    width: 48px;
    background: #000;
  }

  @media screen and (max-width: 990px) {
    #about-carousel-{{ section.id }} .about-carousel__slide {
      flex-basis: 82%;
    }

    #about-carousel-{{ section.id }} .about-carousel__media {
      height: 520px;
    }
  }

  @media screen and (max-width: 749px) {
    #about-carousel-{{ section.id }} .about-carousel__slide {
      flex-basis: 88%;
    }

    #about-carousel-{{ section.id }} .about-carousel__media {
      height: {{ section.settings.mobile_height }}px;
      border-radius: 16px;
    }

    #about-carousel-{{ section.id }} .about-carousel__content {
      top: auto;
      right: 22px;
      bottom: 34px;
      left: 22px;
      width: auto;
      transform: none;
    }

    #about-carousel-{{ section.id }} .about-carousel__eyebrow {
      margin-bottom: 12px;
      font-size: 14px;
    }

    #about-carousel-{{ section.id }} .about-carousel__heading {
      font-size: clamp(30px, 10vw, 44px);
      letter-spacing: -1.2px;
    }

    #about-carousel-{{ section.id }} .about-carousel__button {
      min-width: 132px;
      min-height: 44px;
      margin-top: 24px;
      padding: 10px 22px;
      font-size: 14px;
    }

    #about-carousel-{{ section.id }} .about-carousel__dots {
      gap: 8px;
      margin-top: 20px;
    }

    #about-carousel-{{ section.id }} .about-carousel__dot {
      width: 8px;
      height: 8px;
    }

    #about-carousel-{{ section.id }} .about-carousel__dot.is-active {
      width: 36px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const root = document.querySelector('[data-about-carousel="{{ section.id }}"]');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const track = root.querySelector('.about-carousel__track');
    const slides = Array.from(root.querySelectorAll('.about-carousel__slide'));
    const dots = Array.from(root.querySelectorAll('.about-carousel__dot'));

    if (!track || !slides.length) return;

    let current = 0;
    let startX = 0;
    let endX = 0;
    let dragging = false;
    let timer = null;

    function gapSize() {
      return parseFloat(getComputedStyle(track).gap || 0);
    }

    function update(index, animate = true) {
      current = (index + slides.length) % slides.length;

      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === current);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === current);
      });

      const slideWidth = slides[0].getBoundingClientRect().width;
      const gap = gapSize();
      const viewportWidth = root.getBoundingClientRect().width;
      const slideCenter = current * (slideWidth + gap) + (slideWidth / 2);
      const offset = (viewportWidth / 2) - slideCenter;

      track.style.transition = animate
        ? 'transform .6s cubic-bezier(.22,.61,.36,1)'
        : 'none';

      track.style.transform = 'translate3d(' + offset + 'px,0,0)';
    }

    function next() {
      update(current + 1);
    }

    function prev() {
      update(current - 1);
    }

    function stopAutoplay() {
      if (timer) clearInterval(timer);
      timer = null;
    }

    function startAutoplay() {
      stopAutoplay();
      {% if section.settings.autoplay and section.blocks.size > 1 %}
        timer = setInterval(next, {{ section.settings.autoplay_speed | times: 1000 }});
      {% endif %}
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', function () {
        update(Number(this.dataset.index));
        startAutoplay();
      });
    });

    root.addEventListener('pointerdown', function (e) {
      dragging = true;
      startX = e.clientX;
      endX = e.clientX;
      stopAutoplay();
    });

    root.addEventListener('pointermove', function (e) {
      if (!dragging) return;
      endX = e.clientX;
    });

    root.addEventListener('pointerup', function () {
      if (!dragging) return;
      dragging = false;

      const diff = endX - startX;
      if (Math.abs(diff) > 45) {
        diff < 0 ? next() : prev();
      }

      startAutoplay();
    });

    root.addEventListener('pointercancel', function () {
      dragging = false;
      startAutoplay();
    });

    window.addEventListener('resize', function () {
      update(current, false);
    });

    update(0, false);
    startAutoplay();
  });
</script>

{% schema %}
{
  "name": "About image carousel",
  "tag": "section",
  "class": "section-about-image-carousel",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop slide height",
      "min": 420,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile slide height",
      "min": 360,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Small heading",
          "default": "About Us"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Rooted in Nature, Born in Gir."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About image carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
