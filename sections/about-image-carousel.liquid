{% comment %}
  Section: Center Peek Auto Slider
  File: sections/center-peek-auto-slider.liquid
{% endcomment %}

<section
  id="center-peek-slider-{{ section.id }}"
  class="center-peek-slider-section"
>
  <div
    class="center-peek-slider"
    data-center-peek-slider="{{ section.id }}"
    data-autoplay="{{ section.settings.autoplay }}"
    data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  >
    <div class="center-peek-slider__viewport">
      <div class="center-peek-slider__track">

        {% for block in section.blocks %}
          {% liquid
            assign has_content = false
            if block.settings.eyebrow != blank or block.settings.heading != blank or block.settings.button_label != blank
              assign has_content = true
            endif
          %}

          <article
            class="center-peek-slider__slide"
            data-original-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            <div class="center-peek-slider__media">

              <picture>
                {% if block.settings.mobile_image != blank %}
                  <source
                    media="(max-width: 749px)"
                    srcset="{{ block.settings.mobile_image | image_url: width: 1200 }}"
                  >
                {% endif %}

                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 2400
                    | image_tag:
                      class: 'center-peek-slider__image',
                      loading: 'lazy',
                      widths: '750, 1100, 1500, 1800, 2200, 2400',
                      sizes: '(max-width: 749px) 88vw, 70vw',
                      alt: block.settings.heading
                  }}
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'center-peek-slider__placeholder' }}
                {% endif %}
              </picture>

              {% if has_content %}
                <div class="center-peek-slider__overlay"></div>

                <div class="center-peek-slider__content">
                  {% if block.settings.eyebrow != blank %}
                    <div class="center-peek-slider__eyebrow">
                      {{ block.settings.eyebrow }}
                    </div>
                  {% endif %}

                  {% if block.settings.heading != blank %}
                    <h2 class="center-peek-slider__heading">
                      {{ block.settings.heading }}
                    </h2>
                  {% endif %}

                  {% if block.settings.button_label != blank %}
                    <a
                      href="{{ block.settings.button_link | default: '#' }}"
                      class="center-peek-slider__button"
                    >
                      {{ block.settings.button_label }}
                    </a>
                  {% endif %}
                </div>
              {% elsif block.settings.slide_link != blank %}
                <a
                  href="{{ block.settings.slide_link }}"
                  class="center-peek-slider__full-link"
                  aria-label="Open slide"
                ></a>
              {% endif %}

            </div>
          </article>
        {% endfor %}

      </div>
    </div>

    {% if section.blocks.size > 1 %}
      <div class="center-peek-slider__dots">
        {% for block in section.blocks %}
          <button
            type="button"
            class="center-peek-slider__dot{% if forloop.first %} is-active{% endif %}"
            data-dot-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #center-peek-slider-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #center-peek-slider-{{ section.id }} * {
    box-sizing: border-box;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider {
    width: 100%;
    overflow: hidden;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__viewport {
    width: 100%;
    overflow: hidden;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__viewport.is-dragging {
    cursor: grabbing;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__track {
    display: flex;
    align-items: stretch;
    gap: {{ section.settings.slide_gap }}px;
    will-change: transform;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__slide {
    flex: 0 0 {{ section.settings.desktop_slide_width }}%;
    min-width: 0;
    opacity: .48;
    transition: opacity .35s ease;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__slide.is-active {
    opacity: 1;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__media {
    position: relative;
    width: 100%;
    height: {{ section.settings.desktop_height }}px;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    background: #e8e8e8;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__media picture {
    display: block;
    width: 100%;
    {% comment %} height: 100%; {% endcomment %}
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__image,
  #center-peek-slider-{{ section.id }} .center-peek-slider__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, .18) 40%,
      rgba(0, 0, 0, 0) 75%
    );
    pointer-events: none;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__content {
    position: absolute;
    z-index: 3;
    top: 50%;
    left: 9%;
    {% comment %} width: min(48%, 620px); {% endcomment %}
    color: {{ section.settings.text_color }};
    transform: translateY(-50%);
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__eyebrow {
    margin-bottom: 24px;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.2;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__heading {
    margin: 0;
    color: inherit;
    font-size: clamp(38px, 3.2vw, 62px);
    font-weight: 500;
    letter-spacing: -2px;
    line-height: 1.05;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 156px;
    min-height: 48px;
    margin-top: 38px;
    padding: 12px 28px;
    color: #111111;
    background: #ffffff;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__full-link {
    position: absolute;
    z-index: 4;
    inset: 0;
    display: block;
    -webkit-user-drag: none;
    user-select: none;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 28px;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__dot {
    position: relative;
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    overflow: hidden;
    border-radius: 999px;
    background: #d2d2d2;
    cursor: pointer;
    transition: width .25s ease;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__dot.is-active {
    width: 48px;
    background: #d2d2d2;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider__dot.is-active::after {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: #000000;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider.is-autoplaying .center-peek-slider__dot.is-active::after {
    animation: centerPeekDotProgress-{{ section.id }} {{ section.settings.autoplay_speed }}s linear forwards;
  }

  #center-peek-slider-{{ section.id }} .center-peek-slider.is-paused .center-peek-slider__dot.is-active::after {
    animation-play-state: paused;
  }

  @keyframes centerPeekDotProgress-{{ section.id }} {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }

  @media screen and (max-width: 990px) {
    #center-peek-slider-{{ section.id }} .center-peek-slider__slide {
      flex-basis: 80%;
    }

    
  }

  @media screen and (max-width: 749px) {
    #center-peek-slider-{{ section.id }} {
      padding-top: 16px;
      padding-bottom: 22px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__track {
      gap: 8px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__slide {
      flex-basis: {{ section.settings.mobile_slide_width }}%;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__media {
      {% comment %} height: {{ section.settings.mobile_height }}px; {% endcomment %}
      border-radius: 16px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__content {
      top: auto;
      right: 22px;
      bottom: 30px;
      left: 22px;
      width: auto;
      transform: none;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__eyebrow {
      margin-bottom: 12px;
      font-size: 14px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__heading {
      font-size: clamp(30px, 10vw, 44px);
      letter-spacing: -1px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__button {
      min-width: 132px;
      min-height: 44px;
      margin-top: 22px;
      padding: 10px 22px;
      font-size: 14px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__dots {
      gap: 8px;
      margin-top: 20px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__dot {
      width: 8px;
      height: 8px;
    }

    #center-peek-slider-{{ section.id }} .center-peek-slider__dot.is-active {
      width: 36px;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector('[data-center-peek-slider="{{ section.id }}"]');
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const viewport = root.querySelector('.center-peek-slider__viewport');
    const track = root.querySelector('.center-peek-slider__track');
    const originalSlides = Array.from(root.querySelectorAll('.center-peek-slider__slide'));
    const dots = Array.from(root.querySelectorAll('.center-peek-slider__dot'));

    if (!track || originalSlides.length === 0) return;

    let current = 0;
    let visualIndex = 0;
    let timer = null;
    let startX = 0;
    let currentX = 0;
    let dragging = false;
    let locked = false;
    let dragStartOffset = 0;

    if (originalSlides.length > 1) {
      const firstClone = originalSlides[0].cloneNode(true);
      const lastClone = originalSlides[originalSlides.length - 1].cloneNode(true);

      firstClone.classList.add('is-clone');
      lastClone.classList.add('is-clone');

      track.appendChild(firstClone);
      track.insertBefore(lastClone, track.firstChild);

      visualIndex = 1;
    }

    const allSlides = () => Array.from(track.querySelectorAll('.center-peek-slider__slide'));

    function getGap() {
      return parseFloat(window.getComputedStyle(track).gap || 0);
    }

    function getOffset(index) {
      const slides = allSlides();
      const slideWidth = slides[0].getBoundingClientRect().width;
      const gap = getGap();
      const viewportWidth = root.getBoundingClientRect().width;
      const slideCenter = index * (slideWidth + gap) + (slideWidth / 2);
      return (viewportWidth / 2) - slideCenter;
    }

    function updateActive() {
      allSlides().forEach(slide => slide.classList.remove('is-active'));

      if (originalSlides.length === 1) {
        allSlides()[0].classList.add('is-active');
      } else {
        const slides = allSlides();
        if (slides[visualIndex]) slides[visualIndex].classList.add('is-active');
      }

      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === current);
      });

      restartDotProgress();
    }

    function restartDotProgress() {
      if (root.dataset.autoplay !== 'true' || originalSlides.length <= 1) return;

      root.classList.remove('is-autoplaying');
      void root.offsetWidth;
      root.classList.add('is-autoplaying');
    }

    function moveTo(index, animate = true) {
      visualIndex = index;
      track.style.transition = animate
        ? 'transform .6s cubic-bezier(.22,.61,.36,1)'
        : 'none';
      track.style.transform = `translate3d(${getOffset(visualIndex)}px,0,0)`;
      updateActive();
    }

    function goToReal(index) {
      if (originalSlides.length <= 1) return;

      current = (index + originalSlides.length) % originalSlides.length;
      visualIndex = current + 1;
      moveTo(visualIndex, true);
    }

    function next() {
      if (locked || originalSlides.length <= 1) return;
      locked = true;
      visualIndex += 1;
      current = (current + 1) % originalSlides.length;
      moveTo(visualIndex, true);
    }

    function prev() {
      if (locked || originalSlides.length <= 1) return;
      locked = true;
      visualIndex -= 1;
      current = (current - 1 + originalSlides.length) % originalSlides.length;
      moveTo(visualIndex, true);
    }

    track.addEventListener('transitionend', () => {
      if (originalSlides.length <= 1) {
        locked = false;
        return;
      }

      const slides = allSlides();

      if (visualIndex === slides.length - 1) {
        visualIndex = 1;
        moveTo(visualIndex, false);
      } else if (visualIndex === 0) {
        visualIndex = originalSlides.length;
        moveTo(visualIndex, false);
      }

      locked = false;
    });

    function stopAutoplay() {
      if (timer) clearInterval(timer);
      timer = null;
      root.classList.add('is-paused');
    }

    function startAutoplay() {
      if (timer) clearInterval(timer);
      timer = null;

      if (
        root.dataset.autoplay === 'true' &&
        originalSlides.length > 1
      ) {
        root.classList.remove('is-paused');
        root.classList.add('is-autoplaying');
        restartDotProgress();

        const speed = Number(root.dataset.speed) || 5000;
        timer = setInterval(next, speed);
      } else {
        root.classList.remove('is-autoplaying');
        root.classList.remove('is-paused');
      }
    }

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoplay();
        goToReal(index);
        startAutoplay();
      });
    });

    let dragMoved = false;

    function beginDrag(clientX) {
      if (locked) return;

      dragging = true;
      dragMoved = false;
      startX = clientX;
      currentX = clientX;
      dragStartOffset = getOffset(visualIndex);

      viewport.classList.add('is-dragging');
      stopAutoplay();

      track.style.transition = 'none';
    }

    function updateDrag(clientX) {
      if (!dragging) return;

      currentX = clientX;
      const delta = currentX - startX;

      if (Math.abs(delta) > 4) {
        dragMoved = true;
      }

      track.style.transition = 'none';
      track.style.transform = `translate3d(${dragStartOffset + delta}px, 0, 0)`;
    }

    function endDrag() {
      if (!dragging) return;

      dragging = false;
      viewport.classList.remove('is-dragging');

      const delta = currentX - startX;

      if (Math.abs(delta) > 60) {
        // Natural drag behavior:
        // drag left => next/right slide
        // drag right => previous/left slide
        if (delta < 0) {
          next();
        } else {
          prev();
        }
      } else {
        moveTo(visualIndex, true);
      }

      setTimeout(() => {
        dragMoved = false;
      }, 0);

      startAutoplay();
    }

    /* Desktop mouse drag */
    viewport.addEventListener('mousedown', (event) => {
      if (event.button !== 0) return;
      event.preventDefault();
      beginDrag(event.clientX);
    });

    window.addEventListener('mousemove', (event) => {
      if (!dragging) return;
      event.preventDefault();
      updateDrag(event.clientX);
    });

    window.addEventListener('mouseup', () => {
      endDrag();
    });

    /* Mobile / touch swipe */
    viewport.addEventListener('touchstart', (event) => {
      if (!event.touches || !event.touches[0]) return;
      beginDrag(event.touches[0].clientX);
    }, { passive: true });

    viewport.addEventListener('touchmove', (event) => {
      if (!dragging || !event.touches || !event.touches[0]) return;
      updateDrag(event.touches[0].clientX);
    }, { passive: true });

    viewport.addEventListener('touchend', () => {
      endDrag();
    });

    viewport.addEventListener('touchcancel', () => {
      endDrag();
    });

    /* Prevent slide links from opening after an actual drag */
    root.addEventListener('click', (event) => {
      if (dragMoved) {
        event.preventDefault();
        event.stopPropagation();
      }
    }, true);

    /* Disable browser native image/link dragging */
    root.querySelectorAll('img, a').forEach((element) => {
      element.setAttribute('draggable', 'false');
      element.addEventListener('dragstart', (event) => event.preventDefault());
    });

    window.addEventListener('resize', () => {
      moveTo(visualIndex, false);
    });

    requestAnimationFrame(() => {
      moveTo(visualIndex, false);
      startAutoplay();
    });
  })();
</script>

{% schema %}
{
  "name": "Center peek auto slider",
  "tag": "section",
  "class": "section-center-peek-auto-slider",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Content text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_slide_width",
      "label": "Desktop active slide width",
      "min": 55,
      "max": 85,
      "step": 1,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "mobile_slide_width",
      "label": "Mobile active slide width",
      "min": 75,
      "max": 96,
      "step": 1,
      "unit": "%",
      "default": 88
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Slide gap",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop slide height",
      "min": 420,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile slide height",
      "min": 320,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Content overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "header",
          "content": "Optional content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Small heading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Full image link"
        },
        {
          "type": "url",
          "id": "slide_link",
          "label": "Image link when no content is used"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Center peek auto slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
