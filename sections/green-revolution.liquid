{% comment %}
  Section: Green Revolution
  File: sections/green-revolution.liquid
{% endcomment %}

<section
  id="green-revolution-{{ section.id }}"
  class="green-revolution"
>
  <div class="green-revolution__container">

    <!-- LEFT CONTENT -->
    <div class="green-revolution__content">

      {% if section.settings.eyebrow != blank %}
        <div class="green-revolution__eyebrow">
          {{ section.settings.eyebrow }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="green-revolution__heading">
          {{ section.settings.heading }}
          {% if section.settings.heading_icon != blank %}
            <img
              src="{{ section.settings.heading_icon | image_url: width: 100 }}"
              alt=""
              width="42"
              height="42"
              loading="lazy"
            >
          {% else %}
            <span class="green-revolution__leaf-icon">
              <svg
                viewBox="0 0 64 64"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path d="M50 9C35 9 23 13 16 23c-7 10-5 22-1 30 2-9 8-16 18-22-8 7-12 15-13 25 14-3 24-10 29-21 4-8 4-17 1-26Z" fill="currentColor"/>
                <path d="M14 54c8-15 18-25 34-34" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
              </svg>
            </span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="green-revolution__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="green-revolution__description rte">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="green-revolution__steps">
          {% for block in section.blocks %}
            <div
              class="green-revolution__step"
              {{ block.shopify_attributes }}
            >
              <div class="green-revolution__step-top">

                <div class="green-revolution__step-icon">
                  {% if block.settings.icon != blank %}
                    <img
                      src="{{ block.settings.icon | image_url: width: 100 }}"
                      alt="{{ block.settings.title | escape }}"
                      width="44"
                      height="44"
                      loading="lazy"
                    >
                  {% else %}
                    {% case forloop.index %}
                      {% when 1 %}
                        <svg viewBox="0 0 64 64" aria-hidden="true">
                          <path d="M31 54V29" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="M31 36c-12 0-18-7-18-17 11 0 18 6 18 17Zm1-4c0-12 7-20 19-21 1 12-6 20-19 21Z" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="M19 55h26" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                        </svg>

                      {% when 2 %}
                        <svg viewBox="0 0 64 64" aria-hidden="true">
                          <rect x="10" y="12" width="44" height="40" rx="5" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="m27 24 14 8-14 8Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                        </svg>

                      {% when 3 %}
                        <svg viewBox="0 0 64 64" aria-hidden="true">
                          <path d="M10 34 33 11l21 21-23 23H10Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                          <circle cx="21" cy="43" r="3" fill="currentColor"/>
                          <path d="m37 22 6 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                        </svg>

                      {% when 4 %}
                        <svg viewBox="0 0 64 64" aria-hidden="true">
                          <path d="M15 8h25l9 9v39H15Z" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="M40 8v10h9M23 29h18M23 38h18M23 47h12" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                        </svg>

                      {% when 5 %}
                        <svg viewBox="0 0 64 64" aria-hidden="true">
                          <rect x="14" y="8" width="36" height="48" rx="4" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="M23 18h18M23 29h18M23 40h10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                          <path d="m36 42 4 4 8-10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                        </svg>

                      {% else %}
                        <svg viewBox="0 0 64 64" aria-hidden="true">
                          <rect x="13" y="9" width="38" height="46" rx="4" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="M21 21h22M21 30h22M21 39h14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                          <circle cx="42" cy="43" r="7" fill="none" stroke="currentColor" stroke-width="3"/>
                          <path d="m39 43 2 2 4-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    {% endcase %}
                  {% endif %}
                </div>

                {% unless forloop.last %}
                  <span class="green-revolution__step-line"></span>
                {% endunless %}
              </div>

              <span class="green-revolution__step-number">
                {{ forloop.index }}
              </span>

              {% if block.settings.title != blank %}
                <div class="green-revolution__step-title">
                  {{ block.settings.title }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      <div class="green-revolution__bottom">
        {% if section.settings.button_text != blank %}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="green-revolution__button"
          >
            <span class="green-revolution__button-icon">
              <svg
                viewBox="0 0 64 64"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path d="M50 9C35 9 23 13 16 23c-7 10-5 22-1 30 2-9 8-16 18-22-8 7-12 15-13 25 14-3 24-10 29-21 4-8 4-17 1-26Z" fill="currentColor"/>
                <path d="M14 54c8-15 18-25 34-34" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
              </svg>
            </span>

            <span>{{ section.settings.button_text }}</span>

            <svg
              class="green-revolution__button-arrow"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="m9 5 7 7-7 7"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
        {% endif %}

        {% if section.settings.note != blank %}
          <div class="green-revolution__note">
            {{ section.settings.note }}

            <span class="green-revolution__note-leaf">
              <svg viewBox="0 0 64 64" aria-hidden="true">
                <path d="M50 9C35 9 23 13 16 23c-7 10-5 22-1 30 2-9 8-16 18-22-8 7-12 15-13 25 14-3 24-10 29-21 4-8 4-17 1-26Z" fill="currentColor"/>
              </svg>
            </span>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- RIGHT IMAGE -->
    <div class="green-revolution__visual">

      <div class="green-revolution__image-wrap">
        {% if section.settings.main_image != blank %}
          <picture>
            {% if section.settings.mobile_image != blank %}
              <source
                media="(max-width: 749px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 1000 }}"
              >
            {% endif %}

            {{
              section.settings.main_image
              | image_url: width: 1600
              | image_tag:
                class: 'green-revolution__image',
                loading: 'lazy',
                widths: '600, 900, 1200, 1600',
                sizes: '(max-width: 749px) 100vw, 50vw',
                alt: section.settings.main_image.alt
            }}
          </picture>
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'green-revolution__placeholder' }}
        {% endif %}

        <span class="green-revolution__circle green-revolution__circle--one"></span>
        <span class="green-revolution__circle green-revolution__circle--two"></span>
      </div>

      {% if section.settings.show_discount_badge %}
        <div class="green-revolution__discount">
          <div class="green-revolution__gift-icon">
            <svg viewBox="0 0 64 64" aria-hidden="true">
              <path d="M13 27h38v28H13Z" fill="none" stroke="currentColor" stroke-width="3"/>
              <path d="M9 18h46v10H9Z" fill="none" stroke="currentColor" stroke-width="3"/>
              <path d="M32 18v37" fill="none" stroke="currentColor" stroke-width="3"/>
              <path d="M32 18c-10 0-15-3-15-8 0-3 2-5 5-5 6 0 10 7 10 13Zm0 0c10 0 15-3 15-8 0-3-2-5-5-5-6 0-10 7-10 13Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
            </svg>
          </div>

          {% if section.settings.badge_top_text != blank %}
            <span class="green-revolution__discount-top">
              {{ section.settings.badge_top_text }}
            </span>
          {% endif %}

          {% if section.settings.badge_discount != blank %}
            <strong>{{ section.settings.badge_discount }}</strong>
          {% endif %}

          {% if section.settings.badge_bottom_text != blank %}
            <small>{{ section.settings.badge_bottom_text }}</small>
          {% endif %}
        </div>
      {% endif %}
    </div>

  </div>
</section>

<style>
  #green-revolution-{{ section.id }} {
    width: 100%;
    padding: 16px;
    background: #f3f5f3;
    box-sizing: border-box;
  }

  #green-revolution-{{ section.id }} * {
    box-sizing: border-box;
  }

  #green-revolution-{{ section.id }} .green-revolution__container {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 55%) minmax(0, 45%);
    width: 100%;
    max-width: 1480px;
    min-height: 720px;
    margin: 0 auto;
    overflow: hidden;
    background: #ffffff;
    border-radius: 24px;
  }

  #green-revolution-{{ section.id }} .green-revolution__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 66px 44px 42px 72px;
  }

  #green-revolution-{{ section.id }} .green-revolution__eyebrow {
    margin-bottom: 8px;
    color: #273747;
    font-family: "Brush Script MT", "Segoe Script", cursive;
    font-size: clamp(25px, 2.1vw, 36px);
    font-style: italic;
    line-height: 1.2;
  }

  #green-revolution-{{ section.id }} .green-revolution__heading {
    display: flex;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 10px;
    max-width: 720px;
    margin: 0;
    color: #14512f;
    font-family: Arial, Helvetica, sans-serif;
    font-size: clamp(48px, 5vw, 76px);
    font-weight: 800;
    letter-spacing: -3px;
    line-height: .93;
    text-transform: uppercase;
  }

  #green-revolution-{{ section.id }} .green-revolution__heading p {
    margin: 0;
  }

  #green-revolution-{{ section.id }} .green-revolution__heading img,
  #green-revolution-{{ section.id }} .green-revolution__leaf-icon {
    display: inline-flex;
    flex: 0 0 auto;
    width: 43px;
    height: 43px;
    margin-bottom: 8px;
    color: #72ba45;
    object-fit: contain;
  }

  #green-revolution-{{ section.id }} .green-revolution__leaf-icon svg {
    width: 100%;
    height: 100%;
  }

  #green-revolution-{{ section.id }} .green-revolution__subheading {
    margin-top: 22px;
    color: #76bb45;
    font-family: Arial, Helvetica, sans-serif;
    font-size: clamp(20px, 1.7vw, 29px);
    font-weight: 700;
    line-height: 1.25;
  }

  #green-revolution-{{ section.id }} .green-revolution__description {
    max-width: 660px;
    margin-top: 32px;
    color: #46556a;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 16px;
    line-height: 1.65;
  }

  #green-revolution-{{ section.id }} .green-revolution__description p {
    margin: 0;
  }

  #green-revolution-{{ section.id }} .green-revolution__description a {
    color: #6db53f;
    text-decoration: none;
  }

  #green-revolution-{{ section.id }} .green-revolution__steps {
    display: grid;
    grid-template-columns: repeat(6, minmax(74px, 1fr));
    width: 100%;
    max-width: 680px;
    margin-top: 34px;
  }

  #green-revolution-{{ section.id }} .green-revolution__step {
    position: relative;
    min-width: 0;
    text-align: center;
  }

  #green-revolution-{{ section.id }} .green-revolution__step-top {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #green-revolution-{{ section.id }} .green-revolution__step-icon {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    color: #70b84b;
    background: #f1faed;
    border: 1px solid #bfe3ad;
    border-radius: 50%;
  }

  #green-revolution-{{ section.id }} .green-revolution__step-icon svg,
  #green-revolution-{{ section.id }} .green-revolution__step-icon img {
    width: 27px;
    height: 27px;
    object-fit: contain;
  }

  #green-revolution-{{ section.id }} .green-revolution__step-line {
    position: absolute;
    top: 50%;
    left: calc(50% + 35px);
    width: calc(100% - 70px);
    border-top: 2px dotted #a9b6c8;
    transform: translateY(-50%);
  }

  #green-revolution-{{ section.id }} .green-revolution__step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 19px;
    height: 19px;
    margin: 7px auto 4px;
    color: #ffffff;
    background: #050505;
    border-radius: 50%;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    font-weight: 700;
  }

  #green-revolution-{{ section.id }} .green-revolution__step-title {
    max-width: 90px;
    margin: 0 auto;
    color: #111827;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.3;
  }

  #green-revolution-{{ section.id }} .green-revolution__bottom {
    display: flex;
    align-items: stretch;
    gap: 34px;
    margin-top: 46px;
  }

  #green-revolution-{{ section.id }} .green-revolution__button {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    width: 100%;
    max-width: 400px;
    min-height: 82px;
    padding: 16px 25px 16px 42px;
    color: #ffffff;
    background: #37872c;
    border-radius: 50px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 21px;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    transition: background-color .25s ease, transform .25s ease;
  }

  #green-revolution-{{ section.id }} .green-revolution__button:hover {
    color: #ffffff;
    background: #266d20;
    transform: translateY(-2px);
  }

  #green-revolution-{{ section.id }} .green-revolution__button-icon {
    display: flex;
    flex: 0 0 auto;
    width: 30px;
    height: 30px;
  }

  #green-revolution-{{ section.id }} .green-revolution__button-icon svg {
    width: 100%;
    height: 100%;
  }

  #green-revolution-{{ section.id }} .green-revolution__button-arrow {
    width: 22px;
    height: 22px;
    margin-left: auto;
  }

  #green-revolution-{{ section.id }} .green-revolution__note {
    position: relative;
    min-width: 160px;
    padding: 3px 36px 0 34px;
    color: #384156;
    border-left: 2px solid #d7dce1;
    font-family: "Brush Script MT", "Segoe Script", cursive;
    font-size: 25px;
    font-style: italic;
    line-height: 1.45;
  }

  #green-revolution-{{ section.id }} .green-revolution__note p {
    margin: 0;
  }

  #green-revolution-{{ section.id }} .green-revolution__note-leaf {
    position: absolute;
    right: 0;
    bottom: 7px;
    width: 22px;
    height: 22px;
    color: #74ba45;
  }

  #green-revolution-{{ section.id }} .green-revolution__note-leaf svg {
    width: 100%;
    height: 100%;
  }

  #green-revolution-{{ section.id }} .green-revolution__visual {
    position: relative;
    min-width: 0;
    min-height: 720px;
  }

  #green-revolution-{{ section.id }} .green-revolution__image-wrap {
    position: absolute;
    top: -80px;
    right: -95px;
    bottom: -90px;
    left: -115px;
    overflow: hidden;
    border-radius: 50% 0 0 50%;
  }

  #green-revolution-{{ section.id }} .green-revolution__image,
  #green-revolution-{{ section.id }} .green-revolution__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #green-revolution-{{ section.id }} .green-revolution__placeholder {
    background: #e7efe3;
  }

  #green-revolution-{{ section.id }} .green-revolution__circle {
    position: absolute;
    z-index: 2;
    display: block;
    border: 30px solid rgba(195, 226, 165, .4);
    border-radius: 50%;
  }

  #green-revolution-{{ section.id }} .green-revolution__circle--one {
    top: 52px;
    right: 48px;
    width: 205px;
    height: 205px;
  }

  #green-revolution-{{ section.id }} .green-revolution__circle--two {
    top: 82px;
    right: 78px;
    width: 145px;
    height: 145px;
    border-width: 20px;
    border-color: rgba(255, 255, 255, .28);
  }

  #green-revolution-{{ section.id }} .green-revolution__discount {
    position: absolute;
    z-index: 5;
    top: 43%;
    left: -88px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    width: 190px;
    height: 190px;
    padding: 24px;
    color: #ffffff;
    background: #155432;
    border: 8px solid #ffffff;
    border-radius: 50%;
    box-shadow: 0 12px 24px rgba(0, 0, 0, .18);
    text-align: center;
    transform: translateY(-50%);
  }

  #green-revolution-{{ section.id }} .green-revolution__gift-icon {
    width: 28px;
    height: 28px;
    margin-bottom: 5px;
  }

  #green-revolution-{{ section.id }} .green-revolution__gift-icon svg {
    width: 100%;
    height: 100%;
  }

  #green-revolution-{{ section.id }} .green-revolution__discount-top {
    display: block;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 14px;
    line-height: 1.2;
  }

  #green-revolution-{{ section.id }} .green-revolution__discount strong {
    display: block;
    margin: 2px 0;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 30px;
    font-weight: 800;
    line-height: 1.05;
  }

  #green-revolution-{{ section.id }} .green-revolution__discount small {
    display: block;
    max-width: 80px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 8px;
    line-height: 1.15;
    text-transform: uppercase;
  }

  @media screen and (max-width: 1199px) {
    #green-revolution-{{ section.id }} .green-revolution__container {
      grid-template-columns: minmax(0, 58%) minmax(0, 42%);
      min-height: 680px;
    }

    #green-revolution-{{ section.id }} .green-revolution__content {
      padding: 50px 30px 38px 45px;
    }

    #green-revolution-{{ section.id }} .green-revolution__heading {
      font-size: clamp(44px, 5.5vw, 64px);
    }

    #green-revolution-{{ section.id }} .green-revolution__steps {
      grid-template-columns: repeat(3, 1fr);
      row-gap: 22px;
      max-width: 500px;
    }

    #green-revolution-{{ section.id }} .green-revolution__step:nth-child(3) .green-revolution__step-line {
      display: none;
    }

    #green-revolution-{{ section.id }} .green-revolution__step-line {
      left: calc(50% + 35px);
      width: calc(100% - 70px);
    }

    #green-revolution-{{ section.id }} .green-revolution__bottom {
      gap: 20px;
      margin-top: 34px;
    }

    #green-revolution-{{ section.id }} .green-revolution__button {
      max-width: 350px;
      min-height: 72px;
      padding-left: 28px;
      font-size: 18px;
    }

    #green-revolution-{{ section.id }} .green-revolution__note {
      font-size: 21px;
    }

    #green-revolution-{{ section.id }} .green-revolution__visual {
      min-height: 680px;
    }

    #green-revolution-{{ section.id }} .green-revolution__discount {
      left: -74px;
      width: 165px;
      height: 165px;
    }

    #green-revolution-{{ section.id }} .green-revolution__discount strong {
      font-size: 25px;
    }
  }

  @media screen and (max-width: 899px) {
    #green-revolution-{{ section.id }} {
      padding: 10px;
    }

    #green-revolution-{{ section.id }} .green-revolution__container {
      display: flex;
      flex-direction: column;
      min-height: 0;
      border-radius: 20px;
    }

    #green-revolution-{{ section.id }} .green-revolution__content {
      order: 1;
      padding: 36px 24px 30px;
    }

    #green-revolution-{{ section.id }} .green-revolution__visual {
      order: 2;
      min-height: 520px;
    }

    #green-revolution-{{ section.id }} .green-revolution__image-wrap {
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      border-radius: 48% 48% 0 0 / 15% 15% 0 0;
    }

    #green-revolution-{{ section.id }} .green-revolution__discount {
      top: 0;
      left: 50%;
      width: 150px;
      height: 150px;
      border-width: 6px;
      transform: translate(-50%, -44%);
    }

    #green-revolution-{{ section.id }} .green-revolution__circle--one {
      top: 30px;
      right: 25px;
      width: 160px;
      height: 160px;
      border-width: 24px;
    }

    #green-revolution-{{ section.id }} .green-revolution__circle--two {
      top: 53px;
      right: 49px;
      width: 112px;
      height: 112px;
      border-width: 15px;
    }

    #green-revolution-{{ section.id }} .green-revolution__bottom {
      flex-wrap: wrap;
    }

    #green-revolution-{{ section.id }} .green-revolution__button {
      max-width: 100%;
    }

    #green-revolution-{{ section.id }} .green-revolution__note {
      width: 100%;
      min-width: 0;
      padding: 14px 35px 0 0;
      border-top: 1px solid #d7dce1;
      border-left: 0;
    }
  }

  @media screen and (max-width: 599px) {
    #green-revolution-{{ section.id }} .green-revolution__content {
      padding: 30px 18px 25px;
    }

    #green-revolution-{{ section.id }} .green-revolution__eyebrow {
      font-size: 24px;
    }

    #green-revolution-{{ section.id }} .green-revolution__heading {
      gap: 7px;
