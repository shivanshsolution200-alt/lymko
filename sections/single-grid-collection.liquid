{% assign section_id = section.id %}

<div id="single-collection-{{ section_id }}" class="single-collection-section">
  <div class="single-container page-width">

    <!-- Heading -->
    <h2 class="single-heading" style="text-align: {{ section.settings.heading_alignment }}">
      {{ section.settings.heading }}
    </h2>

    <!-- Subheading -->
    {% if section.settings.subheading != blank %}
      <p class="single-subheading" style="text-align: {{ section.settings.heading_alignment }}">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    {% assign collection = collections[section.settings.collection] %}

    <!-- Products -->
    <div class="single-product-grid">

      {% for product in collection.products limit: 4 %}
             {% render 'card-product-2',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_quick_add: settings.enable_quickadd,
              show_quick_view: settings.enable_quickview,
              show_new_tag: section.settings.show_new_tag,
              section_id: section.id
            %}
      {% endfor %}

    </div>

    {% if collection.url != blank %}
      <div class="single-view-all">
        <a href="{{ collection.url }}" class="single-view-btn">
          View All →
        </a>
      </div>
    {% endif %}

  </div>
</div>

<style>
#single-collection-{{ section_id }} {
  padding: 20px 0;
}

/* SUBHEADING */
#single-collection-{{ section_id }} .single-subheading {
  font-size: 14px;
  color: #777;
  margin-top: -15px;
  margin-bottom: 20px;
}

/* GRID */
#single-collection-{{ section_id }} .single-product-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

/* CARD */
{% comment %} #single-collection-{{ section_id }} .single-product-card {
  background: #fff;
  border-radius: 16px;
  padding: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  transition: 0.3s;
  position: relative;
} {% endcomment %}

{% comment %} #single-collection-{{ section_id }} .single-product-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 18px 45px rgba(0,0,0,0.25);
} {% endcomment %}

/* QUICK ADD ALWAYS */


/* ICONS ALWAYS */
#single-collection-{{ section_id }} .product-icons {
  opacity: 1 !important;
  visibility: visible !important;
  position: absolute;
  top: 10px;
  right: 10px;
}

/* BUTTON */
.quick-add__submit {
  width: 100%;
  border-radius: 10px;
}

/* VIEW ALL */
#single-collection-{{ section_id }} .single-view-all {
  text-align: center;
  margin-top: 25px;
}

#single-collection-{{ section_id }} .single-view-btn {
  padding: 10px 22px;
  border: 1px solid #000;
  border-radius: 25px;
  text-decoration: none;
  color: #000;
}

#single-collection-{{ section_id }} .single-view-btn:hover {
  background: #000;
  color: #fff;
}


/* MOBILE */
@media (max-width: 768px) {
  #single-collection-{{ section_id }} .single-product-grid {
    grid-template-columns: repeat(2, 1fr);
  }
 
  
}

</style>

{% schema %}
{
  "name": "Single Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our latest collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Single Collection Grid"
    }
  ]
}
{% endschema %}