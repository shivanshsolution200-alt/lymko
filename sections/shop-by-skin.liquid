{% assign section_id = section.id %}

<div id="skin-section-{{ section_id }}" class="skin-section">
  <div class="skin-container page-width">

    <!-- Heading -->
    <h2 class="skin-heading" style="text-align: {{ section.settings.heading_alignment }}">
      {{ section.settings.heading }}
    </h2>

    <!-- Tabs -->
    <div class="skin-tabs">
      {% for block in section.blocks %}
        <button class="skin-tab-btn {% if forloop.first %}active{% endif %}" data-tab="tab-{{ section_id }}-{{ forloop.index }}">
          {{ block.settings.tab_name }}
        </button>
      {% endfor %}
    </div>

    <!-- Products -->
    {% for block in section.blocks %}
      {% assign collection = collections[block.settings.collection] %}

      <div class="skin-tab-content {% if forloop.first %}active{% endif %}" id="tab-{{ section_id }}-{{ forloop.index }}">

        <div class="skin-product-row">

          {% for product in collection.products limit: 4 %}
             {% render 'card-product-2',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_quick_add: settings.enable_quickadd,
              show_quick_view: settings.enable_quickview,
              show_new_tag: section.settings.show_new_tag,
              section_id: section.id
            %}
          {% endfor %}

        </div>

        {% if collection.url != blank %}
          <div class="skin-view-all">
            <a href="{{ collection.url }}" class="view-all-btn">
              View All
            </a>
          </div>
        {% endif %}

      </div>
    {% endfor %}

  </div>
</div>

<style>
/* =========================
   SECTION BASE
========================= */
#skin-section-{{ section_id }} {
  padding: 20px 0px;
}

/* Tabs */
#skin-section-{{ section_id }} .skin-tabs {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin-bottom: 25px;
  flex-wrap: wrap;
}

#skin-section-{{ section_id }} .skin-tab-btn {
  padding: 10px 30px;
  border-radius: 13px;
  border: 1px solid #ddd;
  background: #fff;
  cursor: pointer;
  font-size: 14px;
}

#skin-section-{{ section_id }} .skin-tab-btn.active {
  background: #000;
  color: #fff;
}

/* GRID */
#skin-section-{{ section_id }} .skin-product-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}
{% comment %} #skin-section-{{ section_id }} .skin-product-card {
  background: #fff;
  border-radius: 16px;
  padding: 12px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.06);
  transition: 0.3s ease;
  position: relative;
} {% endcomment %}

{% comment %} #skin-section-{{ section_id }} .skin-product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.10);
} {% endcomment %}

/* =========================
   🔥 FORCE ALWAYS VISIBLE UI
========================= */

/* icons always visible */
#skin-section-{{ section_id }} .product-icons,
#skin-section-{{ section_id }} .product-icons.always-visible-icons {
  opacity: 1 !important;
  visibility: visible !important;
  transform: none !important;
  pointer-events: auto !important;
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 5;
}

/* quick view + wishlist hover remove */
#skin-section-{{ section_id }} .product-icons li,
#skin-section-{{ section_id }} .product-icons li a {
  opacity: 1 !important;
  visibility: visible !important;
}


/* image */
#skin-section-{{ section_id }} img {
  width: 100%;
  height: auto;
  border-radius: 11px;
}

/* TITLE */
#skin-section-{{ section_id }} .skin-title {
  font-size: 18px;
  margin: 12px 0 5px;
}

/* PRICE */
#skin-section-{{ section_id }} .skin-price {
  font-size: 16px;
  font-weight: 600;
}

/* Tabs content */
#skin-section-{{ section_id }} .skin-tab-content {
  display: none;
}

#skin-section-{{ section_id }} .skin-tab-content.active {
  display: block;
}

/* View all */
#skin-section-{{ section_id }} .skin-view-all {
  text-align: center;
  margin-top: 25px;
}

#skin-section-{{ section_id }} .view-all-btn {
  display: inline-block;
  padding: 10px 22px;
  border: 1px solid #000;
  border-radius: 25px;
  text-decoration: none;
  color: #000;
  font-size: 14px;
}

#skin-section-{{ section_id }} .view-all-btn:hover {
  background: #000;
  color: #fff;
}

/* MOBILE */
@media (max-width: 768px) {
  #skin-section-{{ section_id }} .skin-product-row {
    grid-template-columns: repeat(1, 1fr);
  }

}
</style>

<script>
(function(){
  const section = document.getElementById("skin-section-{{ section_id }}");
  if(!section) return;

  const buttons = section.querySelectorAll(".skin-tab-btn");
  const contents = section.querySelectorAll(".skin-tab-content");

  buttons.forEach(btn => {
    btn.addEventListener("click", function(){
      const tab = this.getAttribute("data-tab");

      buttons.forEach(b => b.classList.remove("active"));
      contents.forEach(c => c.classList.remove("active"));

      this.classList.add("active");
      section.querySelector("#"+tab).classList.add("active");
    });
  });
})();
</script>

{% schema %}
{
  "name": "Skin Type Tabs Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Skin Type"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_name",
          "label": "Tab Name",
          "default": "Oily"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skin Type Tabs Grid"
    }
  ]
}
{% endschema %}