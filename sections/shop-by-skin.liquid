{% assign section_id = section.id %}

<div id="skin-section-{{ section_id }}" class="skin-section">
  <div class="skin-container page-width">

    <!-- Heading -->
    <h2
      class="skin-heading"
      style="text-align: {{ section.settings.heading_alignment }}"
    >
      {{ section.settings.heading }}
    </h2>

    <!-- Tabs -->
    <div class="skin-tabs">
      {% for block in section.blocks %}
        <button
          type="button"
          class="skin-tab-btn {% if forloop.first %}active{% endif %}"
          data-tab="tab-{{ section_id }}-{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.tab_name }}
        </button>
      {% endfor %}
    </div>

    <!-- Tab Content -->
    {% for block in section.blocks %}

      {% assign collection = collections[block.settings.collection] %}

      <div
        class="skin-tab-content {% if forloop.first %}active{% endif %}"
        id="tab-{{ section_id }}-{{ forloop.index }}"
      >

        {% if collection != blank %}

          <div class="skin-product-row">

            {% for product in collection.products limit: 4 %}

              {% render 'card-product-2',
                card_product: product,
                show_secondary_image: true,
                show_vendor: false,
                show_rating: false,
                show_quick_add: settings.enable_quickadd,
                show_quick_view: settings.enable_quickview,
                show_new_tag: true,
                section_id: section.id
              %}

            {% endfor %}

          </div>

          {% if collection.url != blank %}
            <div class="skin-view-all">
              <a href="{{ collection.url }}" class="view-all-btn">
                View All
              </a>
            </div>
          {% endif %}

        {% endif %}

      </div>

    {% endfor %}

  </div>
</div>


<style>

/* =========================
   SECTION
========================= */

#skin-section-{{ section_id }} {
  padding: 20px 0;
}

#skin-section-{{ section_id }} .skin-heading {
  margin-top: 0;
  margin-bottom: 20px;
}


/* =========================
   TABS
========================= */

#skin-section-{{ section_id }} .skin-tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 25px;
}

#skin-section-{{ section_id }} .skin-tab-btn {
  padding: 10px 30px;

  border-radius: 13px;
  border: 1px solid #dddddd;

  background: #ffffff;
  color: #000000;

  cursor: pointer;

  font-size: 14px;
  line-height: 1.2;

  transition: 0.25s ease;
}

#skin-section-{{ section_id }} .skin-tab-btn:hover {
  border-color: #000000;
}

#skin-section-{{ section_id }} .skin-tab-btn.active {
  background: #000000;
  border-color: #000000;
  color: #ffffff;
}


/* =========================
   TAB CONTENT
========================= */

#skin-section-{{ section_id }} .skin-tab-content {
  display: none;
}

#skin-section-{{ section_id }} .skin-tab-content.active {
  display: block;
}


/* =========================
   PRODUCT GRID
========================= */

#skin-section-{{ section_id }} .skin-product-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 25px;
}


/* =========================
   PRODUCT ICONS
========================= */

/* Eye + Wishlist always visible */

#skin-section-{{ section_id }} .product-icons,
#skin-section-{{ section_id }} .product-icons.always-visible-icons {
  opacity: 1 !important;
  visibility: visible !important;
  transform: none !important;
  pointer-events: auto !important;

  position: absolute;
  top: 10px;
  right: 10px;

  z-index: 9;
}

#skin-section-{{ section_id }} .product-icons li,
#skin-section-{{ section_id }} .product-icons li a {
  opacity: 1 !important;
  visibility: visible !important;
}


/*
=========================================
IMPORTANT
Product image ki koi custom CSS nahi hai.

card-product-2 ki original image +
secondary hover functionality ko
theme handle karega.
=========================================
*/


/* =========================
   VIEW ALL
========================= */

#skin-section-{{ section_id }} .skin-view-all {
  text-align: center;
  margin-top: 25px;
}

#skin-section-{{ section_id }} .view-all-btn {
  display: inline-block;

  padding: 10px 22px;

  border: 1px solid #000000;

  text-decoration: none;

  color: #000000;
  background: transparent;

  font-size: 14px;

  transition: 0.25s ease;
}

#skin-section-{{ section_id }} .view-all-btn:hover {
  background: #000000;
  color: #ffffff;
}


/* =========================
   TABLET
========================= */

@media screen and (max-width: 990px) {

  #skin-section-{{ section_id }} .skin-product-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

}


/* =========================
   MOBILE
========================= */

@media screen and (max-width: 768px) {

  #skin-section-{{ section_id }} .skin-product-row {
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 15px;
  }

  #skin-section-{{ section_id }} .skin-tab-btn {
    padding: 9px 18px;
    font-size: 13px;
  }

  #skin-section-{{ section_id }} .skin-tabs {
    gap: 8px;
    margin-bottom: 20px;
  }

}

</style>


<script>
(function() {

  function initSkinTabs() {

    const section = document.getElementById(
      "skin-section-{{ section_id }}"
    );

    if (!section) return;

    const buttons = section.querySelectorAll(".skin-tab-btn");
    const contents = section.querySelectorAll(".skin-tab-content");


    buttons.forEach(function(button) {

      button.addEventListener("click", function() {

        const tabId = this.getAttribute("data-tab");
        const target = section.querySelector("#" + tabId);

        if (!target) return;


        buttons.forEach(function(btn) {
          btn.classList.remove("active");
        });


        contents.forEach(function(content) {
          content.classList.remove("active");
        });


        this.classList.add("active");
        target.classList.add("active");

      });

    });

  }


  if (document.readyState === "loading") {

    document.addEventListener(
      "DOMContentLoaded",
      initSkinTabs
    );

  } else {

    initSkinTabs();

  }


  /* Shopify Customizer */

  document.addEventListener(
    "shopify:section:load",
    function(event) {

      if (
        event.target.querySelector(
          "#skin-section-{{ section_id }}"
        )
      ) {
        initSkinTabs();
      }

    }
  );

})();
</script>


{% schema %}
{
  "name": "Skin Type Tabs Grid",

  "settings": [

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Skin Type"
    },

    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }

  ],

  "blocks": [

    {
      "type": "tab",
      "name": "Tab",

      "settings": [

        {
          "type": "text",
          "id": "tab_name",
          "label": "Tab Name",
          "default": "Face Serums"
        },

        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }

      ]

    }

  ],

  "max_blocks": 10,

  "presets": [

    {
      "name": "Skin Type Tabs Grid"
    }

  ]

}
{% endschema %}