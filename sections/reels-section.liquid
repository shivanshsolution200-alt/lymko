{% comment %}
  Section: Shoppable Reels Slider
  - Version 7: 
  - Arrow buttons are now always enabled (always highlighted).
  - Removed JavaScript logic that disabled arrows at the start/end of the slider.
{% endcomment %}

<div class="reels-page-width page-width" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="reels-section-title">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="reels-slider-wrapper">
    <div class="reels-container" data-reels-container>
      {%- for block in section.blocks -%}
        <div class="reel-card-wrapper" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.linked_product.url | default: '#' }}" class="reel-card">
            
            {%- if block.settings.reel_video != blank -%}
              <div class="reel-video-wrapper">
                {{ block.settings.reel_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'reel-video', image_size: "720x" }}
              </div>
            {%- else -%}
              <div class="reel-video-placeholder">
                {%- capture 'placeholder' -%}
                  {%- cycle 'lifestyle-1', 'lifestyle-2' -%}
                {%- endcapture -%}
                {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            {%- if block.settings.linked_product != blank -%}
              <div class="product-overlay">
                <div class="product-overlay-image">
                  {{ block.settings.linked_product.featured_image | image_url: width: 100 | image_tag: loading: 'lazy', widths: '50, 100' }}
                </div>
                <span class="product-overlay-title">{{ block.settings.linked_product.title }}</span>
              </div>
            {%- endif -%}
          </a>
        </div>
      {%- endfor -%}
    </div>

    {% comment %} The 'disabled' attribute has been removed from the previous button {% endcomment %}
    <button type="button" class="slider-button slider-button--prev" data-slider-prev>
      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6"><path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></path></svg>
    </button>
    <button type="button" class="slider-button slider-button--next" data-slider-next>
      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6"><path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></path></svg>
    </button>
  </div>
</div>

{% stylesheet %}
  /* .reels-page-width {
    margin: 0 auto;
    padding: 40px 20px;
  } */

  .reels-section-title {
    font-size: 28px;
    font-weight: 700;
    text-align: center;
    margin-bottom: 30px;
  }

  .reels-slider-wrapper {
    position: relative;
    padding: 0 40px;
  }

  .reels-container {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% / 5) - 12.8px);
    overflow-x: auto;
    gap: 16px;
    padding-bottom: 5px;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .reels-container::-webkit-scrollbar {
    display: none;
  }

  .reel-card-wrapper {
    scroll-snap-align: start;
  }

  .reel-card {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
  }
  .reel-card:hover { transform: translateY(-5px); }

  .reel-video-wrapper, .reel-video-placeholder {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  }
  .reel-video, .placeholder-svg {
    width: 100%; height: 100%; object-fit: cover;
  }

  .product-overlay {
    position: absolute; bottom: 12px; left: 12px; right: 12px; 
    display: flex; 
    align-items: flex-start;
    gap: 10px;
    padding: 8px; 
    background: rgba(0, 0, 0, 0.4); 
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px); 
    border-radius: 12px; 
    color: white; 
    text-decoration: none;
    transition: background-color 0.3s ease;
  }
  .reel-card:hover .product-overlay { background: rgba(0, 0, 0, 0.6); }

  .product-overlay-image { 
    flex-shrink: 0; 
    width: 40px; 
    height: 40px; 
    border-radius: 8px; 
    overflow: hidden; 
  }
  .product-overlay-image img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
  }
  
  .product-overlay-title {
    font-size: 13px; 
    font-weight: 500; 
    line-height: 1.4; 
    flex-grow: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .slider-button {
    position: absolute; 
    top: 50%; 
    transform: translateY(-50%);
    z-index: 2;
    background-color: #000 !important; 
    border: 1px solid #e5e5e5;
    border-radius: 50%; 
    width: 40px; 
    height: 40px; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    cursor: pointer; 
    transition: all 0.2s ease; 
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .slider-button:hover { background-color: white; transform: translateY(-50%) scale(1.1); }
  
  /* The :disabled state is no longer used, but we keep the style for safety */
  .slider-button:disabled { 
    opacity: 0.4; 
    cursor: not-allowed; 
    transform: translateY(-50%) scale(1); 
  }
  .slider-button .icon {
    height: .8rem !important;
    color: white;
}

  .slider-button--prev { left: 10px; }
  .slider-button--next { right: 10px; }
  .slider-button .icon-caret {
  transform: rotate(90deg); /* prev = left */
   }

.slider-button--next .icon-caret {
  transform: rotate(-90deg); /* next = right */
   }  

  @media (max-width: 768px) {
    .reels-slider-wrapper { padding: 0; }
    .reels-container {
      grid-auto-columns: 48%;
      padding: 0 16px;
      scroll-snap-type: x proximity;
    }
    .reels-section-title { font-size: 24px; }
    .slider-button { display: none; }

    .product-overlay {
      gap: 8px;
      padding: 6px;
    }
    .product-overlay-image {
      width: 32px;
      height: 32px;
    }
    .product-overlay-title {
      font-size: 12px;
    }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionId = '{{ section.id }}';
    const sliderWrapper = document.querySelector(`[data-section-id="${sectionId}"] .reels-slider-wrapper`);
    if (!sliderWrapper) return;

    const container = sliderWrapper.querySelector('[data-reels-container]');
    const prevButton = sliderWrapper.querySelector('[data-slider-prev]');
    const nextButton = sliderWrapper.querySelector('[data-slider-next]');
    
    if (!container || !prevButton || !nextButton) return;

    // The function and event listeners that disabled the arrows have been removed.

    const scrollToNext = () => {
      const firstReel = container.querySelector('.reel-card-wrapper');
      if (!firstReel) return;
      const scrollAmount = firstReel.offsetWidth + parseFloat(getComputedStyle(container).gap);
      container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    };

    const scrollToPrev = () => {
      const firstReel = container.querySelector('.reel-card-wrapper');
      if (!firstReel) return;
      const scrollAmount = firstReel.offsetWidth + parseFloat(getComputedStyle(container).gap);
      container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    };

    nextButton.addEventListener('click', scrollToNext);
    prevButton.addEventListener('click', scrollToPrev);
    
    // Hides arrows on mobile
    const checkArrowVisibility = () => {
        if (window.innerWidth <= 768) {
            prevButton.style.display = 'none';
            nextButton.style.display = 'none';
        } else {
            prevButton.style.display = 'flex';
            nextButton.style.display = 'flex';
        }
    };
    
    checkArrowVisibility();
    window.addEventListener('resize', checkArrowVisibility);
  });
</script>


{% schema %}
{
  "name": "Shoppable Reels Slider",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by your favourite celebs!"
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "limit": 20,
      "settings": [
        {
          "type": "video",
          "id": "reel_video",
          "label": "Reel Video",
          "info": "Upload a vertical (9:16) video in MP4 format. It will autoplay without sound."
        },
        {
          "type": "product",
          "id": "linked_product",
          "label": "Link Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Reels Slider",
      "category": "Video",
      "blocks": [
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" }
      ]
    }
  ]
}
{% endschema %}