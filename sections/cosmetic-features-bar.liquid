<section
  id="cosmetic-trust-{{ section.id }}"
  class="cosmetic-trust-bar"
  style="
    --section-bg: {{ section.settings.background_color }};
    --icon-color: {{ section.settings.icon_color }};
    --brush-color: {{ section.settings.brush_color }};
    --title-color: {{ section.settings.title_color }};
    --text-color: {{ section.settings.text_color }};
    --divider-color: {{ section.settings.divider_color }};
  "
>
  <div class="cosmetic-trust-bar__inner page-width">

    <div class="cosmetic-trust-bar__items">
      {% for block in section.blocks %}
        <div
          class="cosmetic-trust-item"
          {{ block.shopify_attributes }}
        >

          <div class="cosmetic-trust-item__visual">

            <span class="cosmetic-brush">
              <svg
                viewBox="0 0 120 85"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <path
                  d="M10 23
                  C27 8 51 9 68 12
                  C88 14 108 8 114 19
                  C119 29 102 36 108 44
                  C114 52 103 61 89 63
                  C74 66 68 79 49 73
                  C35 69 26 77 16 67
                  C7 57 18 48 10 40
                  C3 34 2 28 10 23Z"
                  fill="currentColor"
                />
              </svg>
            </span>

            <span class="cosmetic-trust-item__icon">
              {% case block.settings.icon %}

                {% when 'shipping' %}
                  <svg viewBox="0 0 64 64" fill="none">
                    <g
                      stroke="currentColor"
                      stroke-width="2.3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M8 18H39V43H8V18Z"/>
                      <path d="M39 26H49L57 35V43H39V26Z"/>
                      <circle cx="19" cy="46" r="5"/>
                      <circle cx="48" cy="46" r="5"/>
                      <path d="M3 25H12"/>
                      <path d="M2 31H10"/>
                      <path d="M4 37H11"/>
                    </g>
                  </svg>

                {% when 'customers' %}
                  <svg viewBox="0 0 64 64" fill="none">
                    <g
                      stroke="currentColor"
                      stroke-width="2.3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <circle cx="32" cy="22" r="7"/>
                      <circle cx="15" cy="27" r="5"/>
                      <circle cx="49" cy="27" r="5"/>
                      <path d="M21 50C22 41 26 36 32 36C38 36 42 41 43 50"/>
                      <path d="M5 49C6 42 10 38 15 38C20 38 23 41 25 45"/>
                      <path d="M59 49C58 42 54 38 49 38C44 38 41 41 39 45"/>
                      <path d="M24 16C20 12 23 7 27 8C29 8 31 10 32 12C33 10 35 8 38 8C42 8 44 13 40 17L32 24L24 16Z"/>
                    </g>
                  </svg>

                {% when 'payment' %}
                  <svg viewBox="0 0 64 64" fill="none">
                    <g
                      stroke="currentColor"
                      stroke-width="2.3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M32 5L53 14V29C53 42 45 53 32 59C19 53 11 42 11 29V14L32 5Z"/>
                      <path d="M32 19L38 26L34 29L36 39L32 43L28 39L30 29L26 26L32 19Z"/>
                    </g>
                  </svg>

                {% when 'quality' %}
                  <svg viewBox="0 0 64 64" fill="none">
                    <g
                      stroke="currentColor"
                      stroke-width="2.3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M52 10C31 12 19 25 19 46C39 45 50 33 52 10Z"/>
                      <path d="M19 46C28 36 37 28 47 18"/>
                      <path d="M18 47V56"/>
                      <path d="M12 56H25"/>
                      <path d="M28 32C22 26 17 21 12 18C12 32 18 39 25 42"/>
                    </g>
                  </svg>

              {% endcase %}
            </span>

          </div>

          <div class="cosmetic-trust-item__content">
            {% if block.settings.title != blank %}
              <h3>
                {{ block.settings.title }}
              </h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="cosmetic-trust-item__text">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  #cosmetic-trust-{{ section.id }} {
    width: 100%;
    background: var(--section-bg);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #cosmetic-trust-{{ section.id }} * {
    box-sizing: border-box;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-bar__inner {
    width: 100%;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-bar__items {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: center;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item {
    position: relative;
    min-width: 0;
    min-height: 120px;
    padding: 15px 34px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 25%;
    width: 1px;
    height: 50%;
    background: var(--divider-color);
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__visual {
    position: relative;
    width: 92px;
    height: 82px;
    min-width: 92px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-brush {
    position: absolute;
    inset: 0;
    color: var(--brush-color);
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-brush svg {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.72;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__icon {
    position: relative;
    z-index: 2;
    width: 48px;
    height: 48px;
    color: var(--icon-color);
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__content {
    min-width: 0;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item h3 {
    margin: 0 0 8px;
    padding: 0;
    color: var(--title-color);
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    line-height: 1.25;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__text {
    color: var(--text-color);
    font-size: {{ section.settings.text_size }}px;
    font-weight: 400;
    line-height: 1.55;
  }

  #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__text p {
    margin: 0;
  }

  @media screen and (max-width: 1199px) {
    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item {
      padding-left: 20px;
      padding-right: 20px;
      gap: 12px;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__visual {
      width: 112px;
      height: 112px;
      min-width: 112px;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__icon {
      width: 40px;
      height: 40px;
    }
  }

  @media screen and (max-width: 989px) {
    #cosmetic-trust-{{ section.id }} .cosmetic-trust-bar__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item:nth-child(2)::after {
      display: none;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item {
      border-bottom: 1px solid var(--divider-color);
    }
  }

  @media screen and (max-width: 749px) {
    #cosmetic-trust-{{ section.id }} .cosmetic-trust-bar__inner {
      padding-left: 0;
      padding-right: 0;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-bar__items {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-bar__items::-webkit-scrollbar {
      display: none;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item {
      flex: 0 0 85%;
      min-height: 105px;
      padding: 12px 20px;
      scroll-snap-align: start;
      border-bottom: 0;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item:not(:last-child)::after {
      display: block;
      top: 22%;
      height: 56%;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__visual {
      width: 112px;
      min-width: 112px;
      height: 112px;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__icon {
      width: 38px;
      height: 38px;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item h3 {
      font-size: 18px;
    }

    #cosmetic-trust-{{ section.id }} .cosmetic-trust-item__text {
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Cosmetic Trust Bar",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F8F9F3"
    },
    {
      "type": "color",
      "id": "brush_color",
      "label": "Brush background color",
      "default": "#B9C9A6"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#274722"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#365531"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#505050"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#AEB7A6"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "shipping",
              "label": "Free Shipping"
            },
            {
              "value": "customers",
              "label": "Happy Customers"
            },
            {
              "value": "payment",
              "label": "Secure Payment"
            },
            {
              "value": "quality",
              "label": "Assured Quality"
            }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>On all orders<br>above $49</p>"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Cosmetic Trust Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "text": "<p>On all orders<br>above $49</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "customers",
            "title": "2500+ Happy Customers",
            "text": "<p>Trusted by thousands<br>of beauty lovers</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "payment",
            "title": "Secure Payment",
            "text": "<p>100% secure payment<br>guarantee</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "quality",
            "title": "Assured Quality",
            "text": "<p>Premium products<br>you can trust</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}