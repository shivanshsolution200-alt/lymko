{% if customer %}
<section class="login-img-text-{{ section.id }}">
  <div class="login-img-text-wrapper">
    <div class="login-img-text-image">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="">
      {% endif %}
    </div>

    <div class="login-img-text-content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="login-text">{{ section.settings.text }}</div>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="login-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
      {% comment %} {% if customer %}
  <a href="https://thirdparty.com/login?id={{ customer.id  }}&email={{ customer.email  }}" target="_blank">
    Open Third Party
  </a>
{% endif %} {% endcomment %}
    </div>
  </div>
</section>

<style>
.login-img-text-{{ section.id }} {
  padding: {{ section.settings.padding_top }}px 15px {{ section.settings.padding_bottom }}px;
}

.login-img-text-{{ section.id }} .login-img-text-wrapper {
  max-width: {{ section.settings.section_width }}px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: {{ section.settings.image_width }}% 1fr;
  gap: 40px;
  align-items: center;
}

.login-img-text-{{ section.id }} img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: {{ section.settings.image_radius }}px;
}

.login-img-text-{{ section.id }} h2 {
  margin: 0 0 15px;
  font-size: {{ section.settings.heading_size }}px;
}

.login-img-text-{{ section.id }} .login-text {
  margin-bottom: 22px;
  font-size: {{ section.settings.text_size }}px;
  line-height: 1.6;
}

.login-img-text-{{ section.id }} .login-btn {
  display: inline-block;
  background: {{ section.settings.button_bg }};
  color: {{ section.settings.button_color }};
  padding: 13px 28px;
  border-radius: {{ section.settings.button_radius }}px;
  text-decoration: none;
  font-weight: 600;
}

@media(max-width: 768px) {
  .login-img-text-{{ section.id }} .login-img-text-wrapper {
    grid-template-columns: 1fr;
    gap: 25px;
  }

  .login-img-text-{{ section.id }} h2 {
    font-size: 26px;
  }
}
</style>
{% endif %}

{% schema %}
{
  "name": "Login Image Text",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image Width Desktop",
      "min": 30,
      "max": 70,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Section Width",
      "min": 900,
      "max": 1600,
      "step": 50,
      "default": 1200,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Exclusive Video Content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>This section is only visible after customer login.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Watch Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 6,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 50,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Login Image Text"
    }
  ]
}
{% endschema %}