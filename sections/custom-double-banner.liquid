```liquid
{% schema %}
{
  "name": "Custom Double Banner",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Banner Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Banner Image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Your Heading Here"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "SHOP NOW"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Double Banner",
      "blocks": [
        { "type": "banner" },
        { "type": "banner" }
      ]
    }
  ]
}
{% endschema %}

<section class="cdb-section page-width">
  <div class="cdb-container">
    {% for block in section.blocks %}
      {% assign col = block.settings.collection %}

      <a href="{{ col.url }}" class="cdb-item" {{ block.shopify_attributes }}>

        <!-- Image -->
        <div class="cdb-image">

          {% if block.settings.image != blank %}
            <img
              class="cdb-desktop-image"
              src="{{ block.settings.image | image_url: width: 1600 }}"
              alt="{{ block.settings.heading | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% endif %}

          {% if block.settings.mobile_image != blank %}
            <img
              class="cdb-mobile-image"
              src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
              alt="{{ block.settings.heading | escape }}"
              width="{{ block.settings.mobile_image.width }}"
              height="{{ block.settings.mobile_image.height }}"
            >
          {% elsif block.settings.image != blank %}
            <img
              class="cdb-mobile-image"
              src="{{ block.settings.image | image_url: width: 1000 }}"
              alt="{{ block.settings.heading | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% endif %}

        </div>

        <!-- Overlay -->
        <div class="cdb-overlay">
          <h2>{{ block.settings.heading }}</h2>

          {% comment %}
            <span class="cdb-btn">
              {{ block.settings.button_text }}
            </span>
          {% endcomment %}
        </div>

      </a>
    {% endfor %}
  </div>
</section>

<style>
/* SECTION */
.cdb-section {
  padding: 30px 20px;
}

/* GRID */
.cdb-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 25px;
}

/* ITEM */
.cdb-item {
  position: relative;
  display: block;
  overflow: hidden;
}

/* IMAGE */
.cdb-image img {
  width: 100%;
  height: auto;
  object-fit: cover;
  transition: 0.5s ease;
}

/* DESKTOP IMAGE */
.cdb-desktop-image {
  display: block;
}

/* MOBILE IMAGE */
.cdb-mobile-image {
  display: none;
}

/* OVERLAY */
.cdb-overlay {
  position: absolute;
  top: 0;
  left: 0;
  padding: 40px;
  color: #fff;
}

.cdb-overlay h2 {
  font-size: 34px;
  font-weight: 600;
  margin-bottom: 20px;
  max-width: 80%;
}

/* BUTTON */
.cdb-btn {
  display: inline-block;
  background: linear-gradient(90deg, #caa64b, #f5d27a);
  color: #000;
  padding: 10px 22px;
  border-radius: 25px;
  font-size: 14px;
  font-weight: 600;
}

/* BORDER EFFECT */
.cdb-item::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 20px;
  padding: 2px;
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* MOBILE RESPONSIVE */
@media (max-width: 768px) {

  .cdb-container {
    grid-template-columns: 1fr;
  }

  /* Hide Desktop Image */
  .cdb-desktop-image {
    display: none;
  }

  /* Show Mobile Image */
  .cdb-mobile-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .cdb-overlay {
    padding: 20px;
  }

  .cdb-section {
    padding: 0 11px;
  }

  .cdb-overlay h2 {
    font-size: 22px;
  }
}
</style>