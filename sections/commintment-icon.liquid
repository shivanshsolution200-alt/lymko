{% assign section_id = section.id %}

<div id="commitment-{{ section_id }}" class="commitment-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">

    <!-- Heading -->
    <div class="commitment-header" style="text-align: {{ section.settings.text_align }}">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <!-- Icons -->
    <div class="commitment-grid">

      {% for block in section.blocks %}
        <div class="commitment-item" style="text-align: {{ section.settings.text_align }}">

          {% if block.settings.icon != blank %}
            <div class="commitment-icon">
              <img src="{{ block.settings.icon | img_url: '100x' }}" alt="">
            </div>
          {% endif %}

          <h4>{{ block.settings.title }}</h4>
          <p class="subtitle">{{ block.settings.subtitle }}</p>

        </div>
      {% endfor %}

    </div>

  </div>
</div>

<style>
/* 🔒 Scoped CSS */
#commitment-{{ section_id }} {
  padding: 60px 20px;
}

/* Heading */
#commitment-{{ section_id }} .commitment-header h2 {
  font-size: 28px;
  letter-spacing: 2px;
  margin-bottom: 10px;
}

#commitment-{{ section_id }} .commitment-header p {
  max-width: 600px;
  margin: 0 auto 40px;
  font-size: 15px;
  color: #555;
}

/* Grid */
#commitment-{{ section_id }} .commitment-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 30px;
}

/* Item */
#commitment-{{ section_id }} .commitment-item h4 {
  font-size: 14px;
  font-weight: 600;
  margin-top: 15px;
  letter-spacing: 1px;
}

#commitment-{{ section_id }} .subtitle {
  font-size: 13px;
  color: #666;
  margin-top: 5px;
}

/* Icon */
#commitment-{{ section_id }} .commitment-icon img {
  width: 80%;
  height: auto;
  margin: 0 auto;
}

/* 📱 Tablet */
@media (max-width: 1024px) {
  #commitment-{{ section_id }} .commitment-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* 📱 Mobile */
@media (max-width: 768px) {
  #commitment-{{ section_id }} .commitment-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
}
</style>

{% schema %}
{
  "name": "Commitment Icons Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THOUGHTFUL COMMITMENTS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A yes to conscious choices. Our commitment extends to People, Planet, & Pets."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Icon Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CLEAN FORMULATIONS"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "SLS & Paraben Free"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Commitment Icons",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}