 <form
  id="CustomerOtpLoginForm"
  class="customer-otp-login-form"
  novalidate
>
  <h1 id="customer--login" tabindex="-1">
    {{ 'customer.login_page.title' | t }}
  </h1>

  <div class="field field--with-error">
    <label for="CustomerOtpEmail">
      {{ 'customer.login_page.email' | t }}
    </label>

    <input
      type="email"
      name="email"
      id="CustomerOtpEmail"
      autocomplete="email"
      autocorrect="off"
      autocapitalize="off"
      placeholder="{{ 'customer.login_page.email' | t }}"
      required
    >

    <small
      id="CustomerOtpEmailError"
      class="form__message"
      style="display:none;"
    >
      Please enter a valid email address.
    </small>
  </div>

  <div class="link-wrapper">
    <span>OTP will be sent to your email</span>

    <a
      href="/customer_authentication/login?return_to=%2Fpages%2Fdashboard"
    >
      Create account
    </a>
  </div>

  <button type="submit" class="button button--primary">
    Continue
  </button>
</form>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('CustomerOtpLoginForm');
    var emailInput = document.getElementById('CustomerOtpEmail');
    var errorMessage = document.getElementById('CustomerOtpEmailError');

    if (!form || !emailInput) return;

    form.addEventListener('submit', function (event) {
      event.preventDefault();

      var email = emailInput.value.trim();

      if (!email || !emailInput.checkValidity()) {
        errorMessage.style.display = 'block';
        emailInput.focus();
        return;
      }

      errorMessage.style.display = 'none';

      /*
       * Shopify new customer accounts do not support passing or
       * pre-filling the email address from the theme form.
       *
       * User will enter/confirm the email on Shopify's secure page,
       * receive the OTP, and then return to the dashboard.
       */
      window.location.href =
        '/customer_authentication/login?return_to=%2Fpages%2Fdashboard';
    });
  });
</script>
